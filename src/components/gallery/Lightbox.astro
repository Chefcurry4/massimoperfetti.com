---
/**
 * Lightbox — click-to-zoom photo overlay used by /gallery/[slug].
 *
 * Native HTML Popover API (`popover="auto"`) — same convention as the
 * email-cluster and About popovers. ESC + click-outside dismiss. Trigger
 * is supplied by the host page (a `<button popovertarget>` wrapping the
 * photo).
 *
 * Props:
 *   id        Popover element id (so multiple lightboxes can coexist on
 *             one page if needed; usually just "photo-lightbox").
 *   src       Image URL.
 *   alt       Image alt text — required for assistive tech.
 *   caption   Optional caption rendered below the image inside the lightbox.
 */

interface Props {
  id?: string;
  src: string;
  alt: string;
  caption?: string;
}

const { id = 'photo-lightbox', src, alt, caption } = Astro.props;
---

<div id={id} popover="auto" class="lightbox" aria-label="Photo lightbox">
  <button
    type="button"
    class="close"
    popovertarget={id}
    popovertargetaction="hide"
    aria-label="Close lightbox"
  >
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M6 6l12 12M18 6l-12 12" />
    </svg>
  </button>

  <figure class="frame">
    {/* Width/height attrs reserve initial space (CLS); intrinsic dimensions
        take over once the image loads. 1600/1067 ≈ 3:2 mirrors the gallery
        cell's aspect — close enough that the layout shift on real-photo
        load is imperceptible. Phase 8 may migrate to Astro's <Image> for
        per-photo intrinsic dimensions. */}
    <img src={src} alt={alt} width="1600" height="1067" loading="lazy" decoding="async" />
    {caption && <figcaption class="caption text-caption">{caption}</figcaption>}
  </figure>
</div>

<style>
  .lightbox {
    /* Full viewport. Native [popover] sits in the top layer. */
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100dvh;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    color: var(--on-cover);
    display: grid;
    place-items: center;
  }
  .lightbox::backdrop {
    background: var(--scrim-strong);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }

  .close {
    position: absolute;
    top: max(var(--space-4), env(safe-area-inset-top));
    right: max(var(--space-4), env(safe-area-inset-right));
    width: var(--control-h-md);
    height: var(--control-h-md);
    border-radius: var(--radius-pill);
    border: 1px solid var(--on-scrim-border);
    background: var(--scrim-soft);
    color: var(--on-cover);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1;
    transition:
      background var(--duration-fast) var(--ease-out-expo),
      border-color var(--duration-fast) var(--ease-out-expo);
  }
  .close:hover,
  .close:focus-visible {
    background: var(--scrim-medium);
    border-color: var(--on-cover);
  }
  .close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .frame {
    margin: 0;
    padding:
      max(var(--space-5), env(safe-area-inset-top))
      max(var(--space-5), env(safe-area-inset-right))
      max(var(--space-5), env(safe-area-inset-bottom))
      max(var(--space-5), env(safe-area-inset-left));
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    max-width: 100vw;
    max-height: 100dvh;
  }
  .frame img {
    /* Contain within the available space; preserve aspect; pinch-zoom on
       touch devices works because we don't lock pointer-events. */
    display: block;
    max-width: 100%;
    max-height: calc(100dvh - var(--space-7));
    object-fit: contain;
    border-radius: var(--radius-md);
    background: var(--surface);
  }
  .caption {
    color: var(--on-cover);
    text-align: center;
    /* Slightly higher contrast against the dark backdrop. */
    text-shadow: 0 1px 2px var(--scrim-soft);
  }
</style>
