---
/**
 * BentoGrid — the wall.
 *
 * Loads all collection data and singletons, sorts/slices into the fixed
 * layout slots, and lays out four explicit columns with their own internal
 * sub-grids. Mobile flattens to a single column with `order:` rules
 * matching CLAUDE.md's stacking order.
 *
 * Phase 2: cells are non-interactive. Phase 4 wires View Transitions.
 */
import { getCollection } from 'astro:content';

import AboutCell from './AboutCell.astro';
import WorkCell from './WorkCell.astro';
import WritingCell from './WritingCell.astro';
import ProjectsCell from './ProjectsCell.astro';
import GalleryCell from './GalleryCell.astro';
import PlacesCell from './PlacesCell.astro';
import SeeAllCell from './SeeAllCell.astro';
import StubCell from './StubCell.astro';

// --- Data load -------------------------------------------------------------

const allProjects = await getCollection('projects', ({ data }) => !data.draft);
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const work = (await getCollection('work')).sort(
  (a, b) => b.data.period.start.getTime() - a.data.period.start.getTime(),
);

// Writing collection still drives /writing/[slug] + /writing/rss.xml, but
// the bento writing slot is now a pinned newsletter announcement (no
// dynamic data), so we don't load it here.
const gallery = (await getCollection('gallery')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const places = (await getCollection('places')).sort(
  (a, b) => b.data.visitedOn.getTime() - a.data.visitedOn.getTime(),
);

// --- Slot allocation -------------------------------------------------------

// Column 2 has two work slots. Pad with `null` for stubs.
const workSlots: ReadonlyArray<typeof work[number] | null> = [
  work[0] ?? null,
  work[1] ?? null,
];

// Column 3: 2 large + 2 small project slots.
const projLg: ReadonlyArray<typeof allProjects[number] | null> = [
  featuredProjects[0] ?? null,
  featuredProjects[1] ?? null,
];
const projSm: ReadonlyArray<typeof allProjects[number] | null> = [
  featuredProjects[2] ?? null,
  featuredProjects[3] ?? null,
];

---

<div
  class="bento-wall"
  tabindex="0"
  role="region"
  aria-label="Project wall — use arrow keys to scroll horizontally"
>
  <div class="bento-grid">

    {/* -------- COLUMN 1: about hero, full column -------- */}
    {/* Contacts moved to the persistent sidebar in Phase 3, so the about
        cell now occupies the entire column for a stronger first impression. */}
    <div class="col col-1">
      <AboutCell />
    </div>

    {/* -------- COLUMN 2: work-A | work-B (top row) / writing (bottom) -------- */}
    <div class="col col-2">
      <div class="row work-row">
        {
          workSlots[0] ? (
            <WorkCell entry={workSlots[0]} slot="cell-work-a" />
          ) : (
            <StubCell label="work entry" slot="cell-work-a" />
          )
        }
        {
          workSlots[1] ? (
            <WorkCell entry={workSlots[1]} slot="cell-work-b" />
          ) : (
            <StubCell label="work entry" slot="cell-work-b" />
          )
        }
      </div>
      <WritingCell slot="cell-writing" />
    </div>

    {/* -------- COLUMN 3: project-1 / project-2 / [P3 | P4 | see-all] -------- */}
    <div class="col col-3">
      {
        projLg[0] ? (
          <ProjectsCell entry={projLg[0]} variant="lg" slot="cell-project-1" />
        ) : (
          <StubCell label="featured project" slot="cell-project-1" />
        )
      }
      {
        projLg[1] ? (
          <ProjectsCell entry={projLg[1]} variant="lg" slot="cell-project-2" />
        ) : (
          <StubCell label="featured project" slot="cell-project-2" />
        )
      }

      <div class="row project-row">
        {
          projSm[0] ? (
            <ProjectsCell entry={projSm[0]} variant="sm" slot="cell-project-3" />
          ) : (
            <StubCell label="project" slot="cell-project-3" />
          )
        }
        {
          projSm[1] ? (
            <ProjectsCell entry={projSm[1]} variant="sm" slot="cell-project-4" />
          ) : (
            <StubCell label="project" slot="cell-project-4" />
          )
        }
        <SeeAllCell count={allProjects.length} slot="cell-see-all" />
      </div>
    </div>

    {/* -------- COLUMN 4: gallery (top) / places (bottom) -------- */}
    <div class="col col-4">
      {
        gallery.length > 0 ? (
          <GalleryCell entries={gallery} slot="cell-gallery" />
        ) : (
          <StubCell label="gallery" slot="cell-gallery" />
        )
      }
      <PlacesCell entries={places} slot="cell-places" />
    </div>

  </div>
</div>

{/* Scroll hint — shimmer cue prompting horizontal exploration on first
    visit. Auto-hides once the user has scrolled, mobile-hidden via media
    query (the wall flattens to a vertical stack there). */}
<div class="bento-hint" aria-hidden="true">
  <span class="bento-hint__text">scroll right</span>
  <span class="bento-hint__arrow">→</span>
</div>

{/* Scroll progress indicator — desktop only (hidden via media query). */}
<div class="bento-progress" aria-hidden="true"></div>

<style>
  /* Lock the home page to exactly the viewport on desktop. The bento wall
     is meant to fit in 100dvh — if anything inside it (a tall cell, a
     specific browser's rounding, an off-by-one margin calculation) tries
     to push the body taller, this hard-clips it. Scoped to the bento-wall
     component's CSS file means this rule only fires on /, where the wall
     exists; other pages keep their natural scroll behaviour. Mobile is
     excluded because the bento flattens to a vertical stack and is
     supposed to scroll. */
  @media (min-width: 1024px) {
    :global(html),
    :global(body) {
      overflow: hidden;
      /* svh (small viewport height) is constant — it ignores any dynamic
         browser chrome (mobile address bar, Safari toolbar, etc.). dvh
         fluctuates as that chrome shows/hides, which on this layout (main
         flex-centers a fixed-height wall) would re-centre the wall mid-
         scroll and read visually as the wall sliding down then back up.
         svh nails the height in place. */
      height: 100svh;
      /* Prevent any wheel event the wall's handler doesn't intercept from
         leaking into the parent scroll chain (rubber-band, bounce). */
      overscroll-behavior: none;
    }
  }

  /* === Desktop wall (>= 1024px) ===
     The wall anchors to the COLLAPSED sidebar rail width (--sidebar-rail
     = 64px). The expanded sidebar (--sidebar-width = 280) floats over the
     wall via z-index when open — this avoids the layout reflowing every
     time the user expands or collapses the sidebar.
       --wall-inset:    page gutter (clamp 16-32 with viewport)
       --sidebar-rail:  64px (collapsed sidebar visible width)
       --sidebar-gap:   16px between sidebar and wall
  */
  .bento-wall {
    /* Fill the viewport (svh, not dvh — see comment on html/body above for
       why) minus a page gutter at top + bottom. Vertical centering is
       handled by the parent <main> on the home page; with this rule the
       flex-center leaves exactly --wall-inset above and below as breathing
       room. The 560px floor keeps the wall usable on tiny laptop screens.
       Earlier iterations capped the wall at 720px to read as a "central
       strip", but that under-fed the densest cells (PlacesCell map,
       GalleryCell meta block, WritingCell anchored meta-row) and clipped
       their bottoms via the .bento-cell overflow:hidden. No upper cap. */
    height: calc(100svh - 2 * var(--wall-inset));
    min-height: 560px;
    overscroll-behavior: contain;
    margin-top: 0;
    margin-bottom: 0;
    margin-left: calc(
      var(--wall-inset) + var(--sidebar-rail) + var(--sidebar-gap)
    );
    margin-right: var(--wall-inset);
    overflow-x: auto;
    overflow-y: hidden;
    /* Proximity snap — soft alignment to column boundaries when the user
       coasts to a stop near one, but never overrides mid-flight motion.
       Mandatory was hostile to the small per-tick deltas the wheel handler
       produces (the browser kept yanking the wall back to the nearest
       boundary mid-lerp). The 24px scroll-padding still parks a snapped
       column cleanly inside the visible gutter. */
    scroll-snap-type: x proximity;
    scroll-padding-inline: var(--space-5);
    scrollbar-width: none; /* Firefox */
    /* No mask-image. Earlier iterations faded content at the left/right
       edges, but mask-image with a linear-gradient creates a stacking
       context and forces the wall onto its own compositor layer — that
       layer gets re-rasterized on every scroll position change, and on
       weaker GPUs the re-raster produces sub-pixel artifacts that read
       as cards stretching/squashing. Hard cuts at the wall edges via
       overflow: hidden are visually clean and free of paint cost. */
    /* focus-visible outline below — the wall itself receives keyboard focus
       so arrow keys can scroll horizontally. */
  }
  .bento-wall::-webkit-scrollbar {
    display: none;
  }
  .bento-wall:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }

  .bento-grid {
    /*
     * Variable column widths are deliberate (CLAUDE.md §Anti-patterns
     * banishes uniform grids):
     *   col 1 — about hero, full column (contacts moved to sidebar in Phase 3).
     *   col 2 — two work cells side-by-side + writing block.
     *   col 3 — project hero column.
     *   col 4 — gallery + map.
     * Sized at ~85% of the original Phase-2 widths so the wall reads as a
     * balanced central band paired with generous top + bottom gutters.
     */
    display: grid;
    grid-template-columns: 380px 460px 520px 360px;
    grid-template-rows: 1fr;
    grid-auto-flow: column;
    gap: var(--space-4);
    /* Grid padding pairs with wall margin to keep cells off the wall edge. */
    padding: var(--space-5);
    height: 100%;
    width: max-content;
  }

  .col {
    display: grid;
    gap: var(--space-4);
    height: 100%;
    min-width: 0;
    scroll-snap-align: start;
  }
  /* Column-specific row partitions.
     col-1: about hero now occupies the full column (contacts moved to the
     persistent sidebar in Phase 3). */
  .col-1 { grid-template-rows: minmax(0, 1fr); }
  .col-2 { grid-template-rows: minmax(0, 0.58fr) minmax(0, 0.42fr); }
  .col-3 { grid-template-rows: minmax(0, 0.36fr) minmax(0, 0.36fr) minmax(0, 0.28fr); }
  .col-4 { grid-template-rows: minmax(0, 0.55fr) minmax(0, 0.45fr); }

  .row {
    display: grid;
    gap: var(--space-4);
    min-height: 0;
  }
  .work-row {
    grid-template-columns: 1fr 1fr;
  }
  .project-row {
    grid-template-columns: 1fr 1fr 1fr;
  }

  /* === Scroll hint (desktop only) ===
     Shimmer caption at the bottom of the wall. The text uses a moving
     gradient masked through the glyphs (background-clip: text) — same
     technique as Claude's "thinking..." indicator — so a brighter band
     sweeps left to right across muted base text. Sits 24px off the bottom
     edge so it clears the 2px progress bar without overlap. */
  .bento-hint {
    position: fixed;
    bottom: var(--space-5);
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    /* Off-scale 11px caption matches .text-mono-small; defined inline to
       avoid pulling .text-mono-small classes into a fixed-position element
       that lives outside the typographic flow. */
    font-size: 11px;
    line-height: 1;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    pointer-events: none;
    z-index: var(--z-progress);
    opacity: 1;
    transition: opacity 600ms var(--ease-out-expo);
  }
  .bento-hint.is-hidden {
    opacity: 0;
  }

  .bento-hint__text {
    background: linear-gradient(
      90deg,
      var(--text-muted) 0%,
      var(--text-muted) 38%,
      var(--text) 50%,
      var(--text-muted) 62%,
      var(--text-muted) 100%
    );
    background-size: 220% 100%;
    background-clip: text;
    -webkit-background-clip: text;
    color: transparent;
    -webkit-text-fill-color: transparent;
    animation: bento-hint-shimmer 2.6s linear infinite;
  }

  .bento-hint__arrow {
    display: inline-block;
    color: var(--text-muted);
    animation: bento-hint-arrow 2.6s var(--ease-out-expo) infinite;
  }

  @keyframes bento-hint-shimmer {
    from { background-position: 220% 0; }
    to   { background-position: -220% 0; }
  }
  @keyframes bento-hint-arrow {
    0%,
    100% { transform: translateX(0); opacity: 0.55; }
    50%  { transform: translateX(4px); opacity: 1; }
  }

  /* Honour reduced motion: drop both animations and use a flat muted
     caption. The hint still appears (and still auto-hides on scroll); it
     just doesn't shimmer or nudge. */
  @media (prefers-reduced-motion: reduce) {
    .bento-hint { transition: none; }
    .bento-hint__text {
      animation: none;
      background: none;
      color: var(--text-muted);
      -webkit-text-fill-color: var(--text-muted);
    }
    .bento-hint__arrow { animation: none; opacity: 0.8; }
  }

  /* === Scroll progress (desktop only) === */
  .bento-progress {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--accent);
    transform-origin: left;
    transform: scaleX(0);
    transition: transform 90ms linear;
    z-index: var(--z-progress);
    pointer-events: none;
  }

  /* === Mobile stack (< 1024px) ===
     1023.98 (not 1024) sidesteps the ambiguous overlap point between
     min-width:1024px and max-width:1024px queries. */
  @media (max-width: 1023.98px) {
    .bento-wall {
      height: auto;
      margin: 0;
      /* sidebar is a bottom drawer on mobile (Phase 3 Sidebar.astro); the wall
         no longer needs the desktop sidebar-width offset on its left. */
      margin-left: 0;
      overflow-x: visible;
      overflow-y: visible;
      scroll-snap-type: none;
      /* leave room at the bottom for the collapsed sidebar drawer (~64px) */
      padding-bottom: var(--space-7);
    }
    .bento-grid {
      display: flex;
      flex-direction: column;
      grid-auto-flow: row;
      gap: var(--space-3);
      padding: var(--space-4);
      width: auto;
    }
    .col {
      display: contents; /* let children participate in flex order directly */
    }
    .row {
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .row,
    .col-1,
    .col-2,
    .col-3,
    .col-4 {
      /* unset desktop track sizing so cells size to content */
      grid-template-rows: none;
      grid-template-columns: none;
    }

    /* Mobile order — flattened single stack:
       About → Work-A → Work-B → Project-1 → Project-2 → Project-3 → Project-4
       → SeeAll → Writing → Gallery → Places → Contacts. */
    /* Mobile cell order. Contacts moved to the sidebar in Phase 3 — the
       cell-contacts rule is dropped because no element carries that slot. */
    .cell-about     { order: 1; }
    .cell-work-a    { order: 2; }
    .cell-work-b    { order: 3; }
    .cell-project-1 { order: 4; }
    .cell-project-2 { order: 5; }
    .cell-project-3 { order: 6; }
    .cell-project-4 { order: 7; }
    .cell-see-all   { order: 8; }
    .cell-writing   { order: 9; }
    .cell-gallery   { order: 10; }
    .cell-places    { order: 11; }

    /* On mobile, cells size to content — drop the desktop 100% height. */
    :global(.bento-cell) { height: auto; min-height: 200px; }
    :global(.bento-cell.stub) { min-height: 120px; }

    .bento-progress { display: none; }
    .bento-hint { display: none; }
  }
</style>

<script>
  /**
   * Wire the scroll-progress bar AND save/restore the wall's horizontal
   * scrollLeft across navigations.
   *
   * Why save/restore: when the user clicks a project card mid-scroll, navigates
   * to the detail page via a View Transitions morph, and clicks back, the home
   * page re-mounts with scrollLeft = 0 by default (browser scroll restoration
   * only handles the document's own scroll, not a child element's). We persist
   * to sessionStorage and restore on `astro:page-load`, which fires for both
   * fresh loads and View Transitions back-navigation.
   *
   * Re-bind on `astro:page-load` so the binding survives ClientRouter swaps.
   * AbortController teardown is critical here: without it, every navigation
   * back to / would add a second wheel handler whose scroll calls would
   * compound on every event.
   *
   * Wheel-to-horizontal mapping is delegated to the browser's native
   * scroll-animator via `scrollBy({ behavior: 'smooth' })`. An earlier JS
   * RAF lerp version stalled on Windows/Chromium because sub-pixel scrollLeft
   * writes round to no-ops, leaving the RAF spinning forever. The native
   * animator runs on the compositor and re-targets cleanly when wheel events
   * arrive mid-animation.
   */
  const SCROLL_KEY = 'bento-wall-scrollLeft';

  let abortController: AbortController | null = null;

  function bindBentoProgress() {
    const wall = document.querySelector<HTMLElement>('.bento-wall');
    const bar = document.querySelector<HTMLElement>('.bento-progress');
    const hint = document.querySelector<HTMLElement>('.bento-hint');
    if (!wall || !bar) return;

    // Tear down the previous run's listeners before binding fresh. Mirrors
    // the pattern in Sidebar.astro and the GalleryCell cycle script.
    abortController?.abort();
    abortController = new AbortController();
    const { signal } = abortController;

    let storageDebounce: ReturnType<typeof setTimeout> | null = null;
    // Hide-once latch: once the user has scrolled past the threshold the
    // hint stays gone for the rest of the session, even if they scroll
    // back to the start. Re-showing it would read as nagging.
    let hintDismissed = false;
    const HINT_HIDE_PX = 80;

    signal.addEventListener('abort', () => {
      if (storageDebounce !== null) {
        clearTimeout(storageDebounce);
        storageDebounce = null;
      }
    });

    const update = () => {
      const max = wall.scrollWidth - wall.clientWidth;
      const ratio = max > 0 ? wall.scrollLeft / max : 0;
      bar.style.transform = `scaleX(${ratio.toFixed(4)})`;

      // Hide the hint on first meaningful scroll, or immediately if there
      // is no horizontal overflow at all (small-screen edge case where the
      // wall fits the viewport without panning).
      if (hint && !hintDismissed) {
        if (max <= 8 || wall.scrollLeft > HINT_HIDE_PX) {
          hint.classList.add('is-hidden');
          hintDismissed = true;
        }
      }

      // Debounced sessionStorage write — only the last position matters for
      // restore-on-back-nav, so writing 200ms after motion stops is fine.
      if (storageDebounce !== null) clearTimeout(storageDebounce);
      storageDebounce = setTimeout(() => {
        try {
          sessionStorage.setItem(SCROLL_KEY, String(wall.scrollLeft));
        } catch {
          /* storage blocked (private mode) — just skip persistence */
        }
        storageDebounce = null;
      }, 200);
    };

    // Restore previously saved scrollLeft if present. Done before listeners
    // attach so the first `update()` call already reflects the restored value.
    try {
      const stored = sessionStorage.getItem(SCROLL_KEY);
      if (stored) {
        const v = parseInt(stored, 10);
        if (Number.isFinite(v)) {
          wall.scrollLeft = v;
          // Returning visitor — kill the hint without the fade so it
          // doesn't flash in for one frame before update() sees the
          // restored scroll position.
          if (hint && v > HINT_HIDE_PX) {
            hint.classList.add('is-hidden');
            hintDismissed = true;
          }
        }
      }
    } catch {
      /* storage blocked — first paint stays at scrollLeft 0 */
    }

    update();
    wall.addEventListener('scroll', update, { passive: true, signal });
    window.addEventListener('resize', update, { passive: true, signal });

    // No wheel-to-horizontal handler. Earlier iterations intercepted
    // vertical wheel deltaY and translated it into wall.scrollBy(left, ...)
    // so a normal mouse wheel could pan the bento horizontally. That
    // handler is the "algorithm that adjusts card position on user input"
    // and was the source of repeated visual regressions (scroll lag,
    // shadow-bloom waves, stretch/squash, slide-down). It is now gone.
    //
    // Horizontal scroll on desktop is therefore native-only:
    //   – horizontal trackpad gesture (deltaX) → native overflow-x scroll
    //   – Shift+wheel → native horizontal scroll (browser default)
    // Mobile flattens to a vertical stack and scrolls naturally.
  }

  bindBentoProgress();
  document.addEventListener('astro:page-load', bindBentoProgress);
</script>
