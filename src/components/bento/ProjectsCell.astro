---
/**
 * Project cell — column 3.
 *
 * Three render variants:
 *  - "lg": full-width within the column. Cover fills top half, meta below.
 *  - "sm": one third of the column 3 bottom row. Compact, no cover image.
 *
 * Cover image strategy (Phase 2): we have no real cover assets. Phase 1
 * sample frontmatter points at `/projects/flowmap-cover.png` which doesn't
 * exist. We render a gradient placeholder seeded from the project title's
 * first character, plus the title initial overlaid. Phase later swaps in
 * real <img> when cover paths resolve.
 */
import Cell from '../ui/Cell.astro';
import type { CollectionEntry } from 'astro:content';
import { coverHueVars } from '../../lib/cover-color';
import PandaIcon from '../projects/icons/PandaIcon.astro';
import GitHubIcon from '../projects/icons/GitHubIcon.astro';
import LinkedInIcon from '../projects/icons/LinkedInIcon.astro';

interface Props {
  entry: CollectionEntry<'projects'>;
  variant?: 'lg' | 'sm';
  slot?: string;
}

const { entry, variant = 'lg', slot } = Astro.props;
const { title, summary, status, tags, links } = entry.data;

const initial = title.trim().charAt(0).toUpperCase() || '·';
const hasIcon = entry.id === 'unidiary';

// Deterministic hue pair, shared with /projects/[slug] so the View Transitions
// morph (Phase 4) interpolates the gradient continuously.
const coverStyle = coverHueVars(title);

const statusLabel: Record<typeof status, string> = {
  live: 'live',
  archived: 'archived',
  'in-progress': 'in progress',
};

const detailHref = `/projects/${entry.id}`;

// Surface social/repo affordances directly on the card when the entry
// exposes a github.com or linkedin.com link. Rendered as siblings of the
// morph anchor (not children) — nested <a> is invalid markup. Multiple
// matches stack as a small cluster in the top-right corner.
const ghLink = links?.find((l) => /(^|\.)github\.com\//i.test(l.url));
const liLink = links?.find((l) => /(^|\.)linkedin\.com\//i.test(l.url));
const hasActions = Boolean(ghLink || liLink);
---

<div class="card-shell">
<a
  href={detailHref}
  class="card-link"
  transition:name={`poster-projects-${entry.id}`}
>
  <Cell slot={slot} class={`projects-cell variant-${variant}`}>
    {
      variant === 'lg' && (
        <div
          class:list={['cover', { 'cover-bare': hasIcon }]}
          style={hasIcon ? undefined : coverStyle}
          aria-hidden="true"
          transition:name={`poster-projects-${entry.id}-image`}
        >
          {hasIcon ? <PandaIcon class="cover-icon" /> : <span class="cover-initial">{initial}</span>}
        </div>
      )
    }

    <div class="meta">
      <div class="row">
        <p class="text-caption muted">project</p>
        <span class:list={['status-pill', 'text-mono-small', `status-${status}`]}>{statusLabel[status]}</span>
      </div>

      <h2
        class:list={['title', variant === 'lg' ? 'text-h2' : 'text-small']}
        transition:name={`poster-projects-${entry.id}-title`}
      >{title}</h2>

      {variant === 'lg' && <p class="summary text-small muted">{summary}</p>}

      {
        tags.length > 0 && variant === 'lg' && (
          <ul class="tags" aria-label="tags">
            {tags.slice(0, 3).map((t) => (
              <li class="tag-chip text-caption">{t}</li>
            ))}
          </ul>
        )
      }
    </div>
  </Cell>
</a>
{
  hasActions && (
    <div class:list={['card-actions', `card-actions-${variant}`]}>
      {ghLink && (
        <a
          class="action-btn"
          href={ghLink.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${title} repository on GitHub`}
        >
          <GitHubIcon />
        </a>
      )}
      {liLink && (
        <a
          class="action-btn"
          href={liLink.url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${title} on LinkedIn`}
        >
          <LinkedInIcon />
        </a>
      )}
    </div>
  )
}
</div>

<style is:global>
  /* These rules target the .bento-cell element (which lives in Cell.astro's
     scope, not ProjectsCell's), so they're declared :global. The class
     names .projects-cell + .variant-{sm,lg} are unique enough that this
     doesn't risk colliding with other components.

     This file's other styles (cover, meta, cover-initial — elements
     ProjectsCell directly renders) stay scoped in the second <style> block. */
  .projects-cell {
    padding: 0;
    overflow: hidden;
  }
  .projects-cell.variant-sm {
    padding: clamp(var(--space-4), 2vw, var(--space-5));
    gap: var(--space-2);
  }
  /* Lg variant — editorial row layout: small square thumbnail on the left,
     stacked meta on the right. Replaces the previous vertical stack (cover
     top / meta bottom) which gave the giant letter too much visual weight
     and starved the title. The cell becomes flex-row; cover is a fixed-
     width thumbnail; meta absorbs the rest of the width. */
  .projects-cell.variant-lg {
    flex-direction: row;
    align-items: center;
    padding: clamp(var(--space-3), 1.5vw, var(--space-4));
    gap: var(--space-4);
  }
</style>

<style>
  .muted {
    color: var(--text-muted);
  }

  /* Card shell — wraps the morph anchor + the optional github icon as
     siblings, since nesting <a> in <a> is invalid. The shell takes the full
     grid slot (`height: 100%`) so the inner card-link can still fill it. */
  .card-shell {
    position: relative;
    display: block;
    height: 100%;
  }

  /* The anchor wraps the cell so the morph (Phase 4) can carry the whole
     poster across navigation. Keep it transparent — Cell.astro owns the
     visual chrome. `display: block; height: 100%` so the anchor occupies
     the same grid slot as the previous <article>. */
  .card-link {
    display: block;
    height: 100%;
    color: inherit;
    text-decoration: none;
    border-radius: var(--radius-lg);
  }
  .card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* Action cluster — corner row of social/repo icon buttons. Sits above
     the morphing card-link via z-index, with its own hit area so a click
     on an icon opens the link instead of triggering the project-page
     morph. Generalised from a single GitHub button so multiple icons
     (github + linkedin + future others) stack horizontally. */
  .card-actions {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }
  /* Sm variant: tighter inset so the cluster doesn't crowd the compact cell. */
  .card-actions-sm {
    top: var(--space-2);
    right: var(--space-2);
  }

  /* Individual icon button — glass-pill, theme-aware. */
  .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--control-h-sm);
    height: var(--control-h-sm);
    border-radius: var(--radius-pill);
    background: var(--surface-glass);
    backdrop-filter: blur(8px) saturate(140%);
    -webkit-backdrop-filter: blur(8px) saturate(140%);
    border: 1px solid var(--border);
    color: var(--text-muted);
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out-expo),
      border-color var(--duration-fast) var(--ease-out-expo),
      transform var(--duration-fast) var(--ease-out-expo);
  }
  .action-btn :global(svg) {
    width: var(--icon-sm);
    height: var(--icon-sm);
  }
  .action-btn:hover,
  .action-btn:focus-visible {
    color: var(--text);
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }
  .action-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .card-actions-sm .action-btn {
    width: 28px;
    height: 28px;
  }
  .card-actions-sm .action-btn :global(svg) {
    width: var(--icon-xs);
    height: var(--icon-xs);
  }

  .cover {
    /* Shared chrome (gradient + centered initial). lg variant sizing rules
       below target the cover via the :global parent .variant-lg — we can't
       use a normal `.variant-lg .cover` selector because the .variant-lg
       class lives on a different scope (Cell.astro). */
    position: relative;
    min-height: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(
        circle at 30% 30%,
        oklch(70% 0.18 var(--hue) / 0.85),
        oklch(35% 0.14 var(--hue-alt) / 0.95) 70%
      );
    color: var(--on-cover);
  }
  /* Bare variant: drop the gradient + frame so a project mark sits on the
     cell's own surface (Unidiary panda). Color stays at --text so the
     icon reads as a neutral mono glyph instead of the on-cover white. */
  .cover.cover-bare {
    background: transparent;
    color: var(--text);
  }
  /* Square thumbnail in lg variant. :global on the parent ancestor so we
     can navigate the scope boundary (Cell vs ProjectsCell scopes). */
  :global(.projects-cell.variant-lg) .cover {
    flex: 0 0 auto;
    /* Tighter than the original 22% clamp so the cover thumbnail leaves
       more horizontal breathing room for the title + summary on the
       compact central-strip wall. */
    width: clamp(96px, 18%, 132px);
    height: auto;
    aspect-ratio: 1 / 1;
    border-radius: var(--radius-md);
    align-self: center;
  }
  .cover-initial {
    /* Decorative typography — sits outside the body type scale on purpose:
       this is graphic-display, not text-display. */
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(64px, 9vw, 96px);
    line-height: 1;
    letter-spacing: -0.04em;
    text-align: center;
    opacity: 0.95;
    mix-blend-mode: screen;
    pointer-events: none;
    user-select: none;
  }
  :global(.projects-cell.variant-lg) .cover-initial {
    font-size: clamp(44px, 5vw, 64px);
  }
  /* Project icon variant: replaces the giant initial for entries that have
     a dedicated mark (Unidiary → panda). Mono via currentColor inheriting
     from --on-cover; mix-blend-mode kept off so the strokes stay crisp. */
  .cover-icon {
    width: clamp(48px, 7vw, 72px);
    height: auto;
    opacity: 0.95;
    pointer-events: none;
    user-select: none;
  }
  :global(.projects-cell.variant-lg) .cover-icon {
    width: clamp(40px, 4.5vw, 56px);
  }

  .meta {
    padding: clamp(var(--space-4), 2vw, var(--space-5));
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  :global(.projects-cell.variant-sm) .meta {
    padding: 0;
  }
  :global(.projects-cell.variant-lg) .meta {
    /* Cell padding handles inset; meta sits flush against cover with the
       parent's gap providing horizontal breathing room. min-width: 0 so
       the title can ellipsis-wrap in narrow cell widths. */
    padding: 0;
    flex: 1 1 auto;
    min-width: 0;
    justify-content: center;
  }

  .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
  }
  /* .status-pill + .status-{kind} variants live in global.css; no local
     redefinition needed. */

  .title {
    margin: 0;
    color: var(--text);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  /* Sm variant title — smaller text so long titles ("Wind Power
     Forecasting with Graph Neural Networks", "Heterogeneous Missing-Data
     Imputation with HI-VAE") fit more readably in the compact cell. Adds
     title weight + tight rhythm on top of the inherited .text-small
     sizing so it still reads as a card title, not body. Line-clamps to
     3 lines with a normal ellipsis — the soft fade lives on the cell
     chrome below, not on the text. */
  :global(.projects-cell.variant-sm) .title {
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.005em;
    -webkit-line-clamp: 3;
    line-clamp: 3;
  }
  /* Sm cell — soft bottom-edge fade. Mask-image dissolves the cell's
     own chrome (background + border) over the bottom 18% of its height,
     reading as a "the wall keeps going" cue without obscuring the title,
     which sits in the upper portion of the cell. The .card-actions
     cluster lives outside the masked .bento-cell (it's a sibling inside
     .card-shell), so the github/linkedin icons stay fully opaque. */
  :global(.projects-cell.variant-sm) {
    mask-image: linear-gradient(to bottom, black 82%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 82%, transparent 100%);
  }
  .summary {
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (min-height: 1080px) {
    .summary {
      -webkit-line-clamp: 3;
      line-clamp: 3;
    }
  }
  .tags {
    list-style: none;
    padding: 0;
    margin: auto 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }
  /* .tag-chip lives in global.css. */
</style>
