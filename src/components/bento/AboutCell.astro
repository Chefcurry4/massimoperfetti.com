---
/**
 * About cell — hero of the wall.
 *
 * Layout (top to bottom):
 *   1. Portrait — full-width, ~40% of cell height, rounded.
 *      Implemented as a <div> with background-image so a missing /me.jpg
 *      degrades to the layered OKLCH gradient instead of a broken-image icon.
 *      An <img> approach would either show the broken icon or require inline
 *      JS (`onerror=`) which we don't want for CSP reasons.
 *   2. Eyebrow caption.
 *   3. Name (display serif, h1).
 *   4. Role line.
 *   5. Body line (clamped to 2).
 *   6. "→ read more" CTA — links to /about.
 *
 * Glass surface (per CLAUDE.md §Liquid glass selective use).
 *
 * Portrait file: public/me.webp.
 * Preload directive (`<link rel="preload" as="image" fetchpriority="high">`)
 * lives in Base.astro for the home route — speeds up LCP since the bento
 * AboutCell sits above the fold and its portrait is the largest contentful
 * paint candidate on the wall.
 */
import Cell from '../ui/Cell.astro';
import { getImage } from 'astro:assets';
import { about } from '../../data/about';
import { site } from '../../data/site';
import portraitMobileSrc from '../../assets/in.png';

// Mobile gets a different portrait — desktop's /me.webp is composed for the
// 280×280 square in the bento rail; the mobile cell renders full-width × 280
// (a wide rectangle) and benefits from a different crop. Run through Astro's
// asset pipeline so the user-supplied PNG is served as a hashed WebP at a
// width sized for retina phones (1080px effective at 360×3x; 1200 gives
// headroom). Build-time only — zero client cost.
const portraitMobile = await getImage({
  src: portraitMobileSrc,
  width: 1200,
  format: 'webp',
});
---

<Cell glass slot="cell-about" class="about-cell">
  {/* --portrait-mobile carries the build-hashed WebP URL into the scoped
      stylesheet so the @media block below can swap the background-image
      without inlining the URL twice or duplicating the rule. */}
  <div
    class="portrait"
    role="img"
    aria-label={`Portrait of ${site.name}`}
    style={`--portrait-mobile: url('${portraitMobile.src}');`}
  ></div>

  <div class="content">
    <p class="text-caption muted">about</p>
    {/* h1 because this cell is the bento home page's primary heading.
        AboutContent on /about owns its own h1 so there's no collision —
        AboutCell is only ever rendered on /. */}
    <h1 class="text-h1 name">{site.name}</h1>
    <p class="role text-small">{about.role}</p>
    <p class="body text-small muted">{about.body[0]}</p>

    <a
      href="/about"
      class="cta text-caption"
      data-astro-prefetch
    >
      <span aria-hidden="true">→</span>
      <span>read more</span>
    </a>
  </div>
</Cell>

<style>
  .muted {
    color: var(--text-muted);
  }

  .about-cell {
    /* Inherits Cell's --space-3 gap. */
  }

  .portrait {
    /* Fixed height — no flex grow, no aspect-ratio, no max-height. The
       previous flex+aspect-ratio combination interacted unpredictably
       across browsers (flex item sizing winning over max-height under
       certain content states), letting the photo render much taller than
       intended and pushing the cell past the wall's row allocation.
       width: 100% fills the cell; height is locked. */
    flex: 0 0 280px;
    width: 100%;
    height: 280px;
    border-radius: var(--radius-md);
    overflow: hidden;
    /* Layered: gradient fallback below, photo on top. If /me.webp 404s, the
       gradient remains visible. The first background-color sits underneath
       both for further safety in older renderers. */
    background-color: var(--surface);
    background-image:
      url('/me.webp'),
      var(--gradient-cool);
    background-size: cover, cover;
    background-position: center top, center;
    background-repeat: no-repeat, no-repeat;
    border: 1px solid var(--border);
  }
  /* === Mobile layout =================================================
   * Stacked (portrait above content), same as desktop, but the portrait
   * uses aspect-ratio: 1 instead of a fixed 280px height. The old
   * full-width × 280 rectangle was forcing `background-size: cover` to
   * crop the face down to just the eyes and forehead; a 1:1 box shows the
   * whole head-and-shoulders. The mobile-specific photo (src/assets/in.png)
   * is hashed to WebP via getImage() and injected through --portrait-mobile.
   * ================================================================== */
  @media (max-width: 1023.98px) {
    .portrait {
      /* Reset the desktop fixed-280px height — let aspect-ratio drive it
         instead so the photo's natural proportions are preserved. The
         flex basis switches from a height value to `auto` for the same
         reason. width: 100% fills the cell horizontally as before. */
      flex: 0 0 auto;
      width: 100%;
      height: auto;
      aspect-ratio: 1 / 1;
      background-image: var(--portrait-mobile), var(--gradient-cool);
    }
  }

  .content {
    /* fixed-basis so the portrait shrinks before this does — meta is the
       priority content. `flex: 0 0 auto` avoids the content squeezing. */
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 0 0 auto;
    min-height: 0;
  }

  .name {
    margin: 0;
    color: var(--text);
    /* slight tightening for the dense column */
    font-size: clamp(28px, 3.6vw, 36px);
    line-height: 1.05;
  }

  .role {
    margin: 0;
    color: var(--text);
  }

  .body {
    /* clamp tightly so the cell never overflows even at small viewport heights;
       phase-7 popup will surface the full body. */
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-height: 800px) {
    .body {
      -webkit-line-clamp: 1;
      line-clamp: 1;
    }
  }

  .cta {
    /* Same eyebrow caption sizing, transitions to accent on hover. */
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    /* The visible label is text-caption (~17px tall) — far below the 44px
       tap floor. Vertical padding + min-height lifts the click region to
       spec without changing visual rhythm: margin-top: auto pins the
       label to the bottom of .content, padding: var(--space-2) 0 absorbs
       stray finger taps above and below the eyebrow. No horizontal pad
       so the inline alignment stays. */
    min-height: var(--tap-min);
    padding: var(--space-2) 0;
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-normal) var(--ease-out-expo);
    width: fit-content;
  }
  .cta:hover,
  .cta:focus-visible {
    color: var(--accent);
  }
  .cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }
</style>
