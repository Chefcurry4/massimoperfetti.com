---
/**
 * About cell — hero of the wall.
 *
 * Layout (top to bottom):
 *   1. Portrait — full-width, ~40% of cell height, rounded.
 *      Implemented as a <div> with background-image so a missing /me.jpg
 *      degrades to the layered OKLCH gradient instead of a broken-image icon.
 *      An <img> approach would either show the broken icon or require inline
 *      JS (`onerror=`) which we don't want for CSP reasons.
 *   2. Eyebrow caption.
 *   3. Name (display serif, h1).
 *   4. Role line.
 *   5. Body line (clamped to 2).
 *   6. "→ read more" CTA, accent on hover.
 *
 * Glass surface (per CLAUDE.md §Liquid glass selective use).
 *
 * Portrait file: public/me.jpeg.
 */
import Cell from '../ui/Cell.astro';
import { about } from '../../data/about';
import { site } from '../../data/site';
---

<Cell glass slot="cell-about" class="about-cell">
  <div
    class="portrait"
    role="img"
    aria-label={`Portrait of ${site.name}`}
  ></div>

  <div class="content">
    <p class="text-caption muted">about</p>
    <h2 class="text-h1 name">{site.name}</h2>
    <p class="role text-small">{about.role}</p>
    <p class="body text-small muted">{about.body[0]}</p>

    <button
      type="button"
      class="cta text-caption"
      popovertarget="about-popover"
      aria-label="Open about"
    >
      <span aria-hidden="true">→</span>
      <span>read more</span>
    </button>
  </div>
</Cell>

<style>
  .muted {
    color: var(--text-muted);
  }

  .about-cell {
    /* Inherits Cell's --space-3 gap. */
  }

  .portrait {
    /* `flex: 1 1 0; min-height: 0` lets the portrait shrink when the cell is
       short (so the meta block always renders fully). aspect-ratio gives it
       a sensible footprint when there's room; max-height caps it at the
       intended hero size. The cap is more generous now that AboutCell owns
       the full column-1 height (Phase 3 moved contacts to the sidebar). */
    flex: 1 1 0;
    min-height: 0;
    width: 100%;
    aspect-ratio: 4 / 5;
    max-height: 480px;
    border-radius: var(--radius-md);
    overflow: hidden;
    /* Layered: gradient fallback below, photo on top. If /me.jpg 404s, the
       gradient remains visible. The first background-color sits underneath
       both for further safety in older renderers. */
    background-color: var(--surface);
    background-image:
      url('/me.jpeg'),
      var(--gradient-cool);
    background-size: cover, cover;
    background-position: center top, center;
    background-repeat: no-repeat, no-repeat;
    border: 1px solid var(--border);
  }

  .content {
    /* fixed-basis so the portrait shrinks before this does — meta is the
       priority content. `flex: 0 0 auto` avoids the content squeezing. */
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    flex: 0 0 auto;
    min-height: 0;
  }

  .name {
    margin: 0;
    color: var(--text);
    /* slight tightening for the dense column */
    font-size: clamp(28px, 3.6vw, 36px);
    line-height: 1.05;
  }

  .role {
    margin: 0;
    color: var(--text);
  }

  .body {
    /* clamp tightly so the cell never overflows even at small viewport heights;
       phase-7 popup will surface the full body. */
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-height: 800px) {
    .body {
      -webkit-line-clamp: 1;
      line-clamp: 1;
    }
  }

  .cta {
    /* Same eyebrow caption sizing, but transitions to accent on hover.
       The element is a <button> in Phase 7 (popovertarget); reset native
       button chrome so it matches the visual treatment of the prior <a>. */
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--text-muted);
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    font: inherit;
    transition: color var(--duration-normal) var(--ease-out-expo);
    width: fit-content;
  }
  .cta:hover,
  .cta:focus-visible {
    color: var(--accent);
  }
  .cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }
</style>
