---
/**
 * Contacts cell — bottom of column 1.
 *
 * Renders a vertical list of channels from data/contacts.ts.
 * Each entry is an anchor in Phase 2 because contacts are external links
 * (no internal navigation, no view-transition concerns).
 */
import Cell from '../ui/Cell.astro';
import { contacts, type ContactKind } from '../../data/contacts';

const iconStrokeWidth = 1.6;

/**
 * Inline icon paths keyed by contact kind. Single-color stroke, 24px viewBox,
 * uses currentColor so the theme controls them. Kept local so this cell has
 * no external icon-library dep.
 */
const iconPaths: Record<ContactKind, string> = {
  email:
    'M3 6.5h18v11H3zM3.5 7l8.5 6.5L20.5 7',
  github:
    'M9 19c-4 1.4-4-2-6-2.5M15 21v-3.5a3.4 3.4 0 0 0-.9-2.6c3-.3 6-1.5 6-6.5a5 5 0 0 0-1.4-3.5 4.6 4.6 0 0 0-.1-3.5s-1.1-.4-3.6 1.4a12.3 12.3 0 0 0-6.5 0C5.9 1 4.8 1.4 4.8 1.4a4.6 4.6 0 0 0-.1 3.5A5 5 0 0 0 3.3 8.4c0 5 3 6.2 6 6.5A3.4 3.4 0 0 0 8.4 17.5V21',
  linkedin:
    'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2zM4 6.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z',
  x:
    'M4 4l16 16M20 4L4 20',
  scholar:
    'M22 10v6M2 10l10-5 10 5-10 5z M6 12v5c3 3 9 3 12 0v-5',
  cv:
    'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8',
};
---

<Cell slot="cell-contacts">
  <p class="text-caption muted">contacts</p>

  <ul class="list">
    {
      contacts.map((c) => (
        <li>
          <a class="row" href={c.url} rel={c.kind === 'email' ? undefined : 'me noopener'}>
            <span class="icon" aria-hidden="true">
              <svg
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width={iconStrokeWidth}
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={iconPaths[c.kind]} />
              </svg>
            </span>
            <span class="label text-small">{c.label}</span>
            <span class="handle text-mono-small muted">{c.handle}</span>
          </a>
        </li>
      ))
    }
  </ul>
</Cell>

<style>
  .muted {
    color: var(--text-muted);
  }
  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .row {
    display: grid;
    grid-template-columns: 24px 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .row:hover {
    color: var(--text);
  }
  .row:hover .handle {
    color: var(--text);
  }
  .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text);
  }
  .handle {
    /* truncate long handles instead of wrapping; type styling comes from
       .text-mono-small in global.css. */
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    max-width: 14ch;
  }
</style>
