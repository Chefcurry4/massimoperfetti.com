---
/**
 * Contacts cell — compact icon row by default, expands on cell hover or
 * any anchor focus to reveal label + handle for each channel.
 *
 * Expansion is pure CSS via the `grid-template-rows: 0fr → 1fr` trick:
 * the detail panel is a grid item with min-height:0, and the parent grid's
 * row track grows from 0 to 1fr, transitioning naturally without measuring
 * the content. No JS, no max-height guesswork.
 *
 * Each anchor has `aria-label` so a screen reader gets the channel name
 * even when the visual label is collapsed.
 */
import Cell from '../ui/Cell.astro';
import { contacts, type ContactKind } from '../../data/contacts';

const iconStrokeWidth = 1.7;

const iconPaths: Record<ContactKind, string> = {
  email: 'M3 6.5h18v11H3zM3.5 7l8.5 6.5L20.5 7',
  github:
    'M9 19c-4 1.4-4-2-6-2.5M15 21v-3.5a3.4 3.4 0 0 0-.9-2.6c3-.3 6-1.5 6-6.5a5 5 0 0 0-1.4-3.5 4.6 4.6 0 0 0-.1-3.5s-1.1-.4-3.6 1.4a12.3 12.3 0 0 0-6.5 0C5.9 1 4.8 1.4 4.8 1.4a4.6 4.6 0 0 0-.1 3.5A5 5 0 0 0 3.3 8.4c0 5 3 6.2 6 6.5A3.4 3.4 0 0 0 8.4 17.5V21',
  linkedin:
    'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2zM4 6.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z',
  x: 'M4 4l16 16M20 4L4 20',
  scholar:
    'M22 10v6M2 10l10-5 10 5-10 5z M6 12v5c3 3 9 3 12 0v-5',
  cv: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8',
};
---

<Cell slot="cell-contacts" class="contacts-cell">
  <header class="head">
    <p class="text-caption muted">contacts</p>
    <span class="hint text-caption muted" aria-hidden="true">hover</span>
  </header>

  <ul class="row" aria-label="contact channels">
    {
      contacts.map((c) => (
        <li>
          <a
            class="icon-link"
            href={c.url}
            aria-label={`${c.label} — ${c.handle}`}
            rel={c.kind === 'email' ? undefined : 'me noopener'}
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width={iconStrokeWidth}
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d={iconPaths[c.kind]} />
            </svg>
          </a>
        </li>
      ))
    }
  </ul>

  <div class="expand">
    <ul class="detail-list">
      {
        contacts.map((c) => (
          <li class="detail-row">
            <span class="label text-small">{c.label}</span>
            <a class="handle text-mono-small" href={c.url}>
              {c.handle}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</Cell>

<style>
  .muted {
    color: var(--text-muted);
  }

  .contacts-cell {
    /* The expand panel uses a grid trick — needs the cell to be flex with
       a deterministic flow. We're inheriting Cell's flex column, which works
       because `.expand` itself becomes the grid container. */
    gap: 0.6rem;
  }

  .head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }
  .hint {
    /* Hidden by default; only shown where hover is meaningful (mouse/trackpad).
       On touch devices the panel is always-expanded (see media query below)
       so the "hover" affordance copy would lie. */
    display: none;
    transition: opacity var(--duration-normal) var(--ease-out-expo);
  }
  @media (hover: hover) {
    .hint {
      display: inline;
    }
    .contacts-cell:hover .hint,
    .contacts-cell:focus-within .hint {
      opacity: 0;
    }
  }

  .row {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    color: var(--text);
    transition:
      color var(--duration-normal) var(--ease-out-expo),
      border-color var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
  }
  .icon-link:hover,
  .icon-link:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .icon-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /*
   * Expand panel — collapsed by default (grid row 0fr -> the inner div with
   * min-height:0 collapses to height 0). On hover/focus-within of the cell,
   * the row track grows to 1fr and the content reveals. The transition runs
   * on grid-template-rows so it animates smoothly without knowing the inner
   * content height ahead of time.
   */
  .expand {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--duration-normal) var(--ease-out-expo);
  }
  .expand > * {
    min-height: 0;
    overflow: hidden;
  }
  .contacts-cell:hover .expand,
  .contacts-cell:focus-within .expand {
    grid-template-rows: 1fr;
  }

  /* Touch / no-hover: there is no `:hover` to gate on, and `:focus-within`
     would only briefly fire while a user is mid-tab between icons. Default
     to expanded so the labels + handles are always visible. */
  @media (hover: none) {
    .expand {
      grid-template-rows: 1fr;
    }
  }

  .detail-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .detail-row {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.4rem 0;
    border-top: 1px solid var(--border);
  }
  .detail-row:first-child {
    border-top: none;
    padding-top: 0.5rem;
  }
  .label {
    color: var(--text);
  }
  .handle {
    color: var(--text-muted);
    text-align: right;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    transition: color var(--duration-normal) var(--ease-out-expo);
  }
  .handle:hover,
  .handle:focus-visible {
    color: var(--accent);
  }
</style>
