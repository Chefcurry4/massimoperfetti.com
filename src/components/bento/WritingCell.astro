---
/**
 * Writing cell — bottom of column 2.
 *
 * Pinned newsletter announcement. The cell *body* is deliberately
 * non-interactive (no <a> wrapper around the cell, no detail page). The
 * one clickable element is the newsletter icon in the bottom-right corner,
 * which opens https://perfettis-notes.beehiiv.com/ in a new tab — same
 * destination the sidebar newsletter icon points at.
 *
 * Edit the body copy directly here when the announcement changes.
 */
import Cell from '../ui/Cell.astro';
import { site } from '../../data/site';

interface Props {
  slot?: string;
}

const { slot } = Astro.props;

const newsletterUrl = 'https://perfettis-notes.beehiiv.com/';
---

<Cell slot={slot}>
  <p class="text-caption muted">newsletter</p>
  <h2 class="text-h3 title">Perfettis' Notes</h2>
  <p class="lede text-body muted">
    My brother Matteo and I launched a newsletter — free, in Italian. We
    write about academic choices, engineering, AI and ML, motivation, work
    experience, and the advice we wish we'd had along the way.
  </p>
  <p class="closer text-small">
    If it helps a few Italian students find their way a bit better, that's
    already a win.
  </p>
  <div class="meta-row">
    <p class="meta text-caption muted">free · in italian</p>
    <a
      class="subscribe"
      href={newsletterUrl}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={`Subscribe to Perfettis' Notes — opens ${site.name === 'Massimo Perfetti' ? 'beehiiv' : 'newsletter'} in a new tab`}
    >
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.7"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M4 6h12v10H4zM4 6l6 5 6-5M19 9h3M19 12h3M19 15h3" />
      </svg>
    </a>
  </div>
</Cell>

<style>
  .muted {
    color: var(--text-muted);
  }
  .title {
    margin: 0;
    color: var(--text);
  }
  .lede {
    margin: 0;
    /* Clamp so the cell stays bounded at typical viewports. */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-height: 800px) {
    .lede {
      -webkit-line-clamp: 2;
      line-clamp: 2;
    }
  }
  .closer {
    margin: 0;
    color: var(--text);
  }

  .meta-row {
    /* margin-top: auto pushes the meta line + subscribe icon to the bottom
       of the cell so the announcement reads as anchored editorial copy. */
    margin: auto 0 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
  }
  .meta {
    margin: 0;
  }

  .subscribe {
    /* Icon-only link — same visual language as the sidebar contacts row. */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--control-h-sm);
    height: var(--control-h-sm);
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
    text-decoration: none;
    transition:
      color var(--duration-fast) var(--ease-out-expo),
      border-color var(--duration-fast) var(--ease-out-expo),
      transform var(--duration-fast) var(--ease-out-expo);
  }
  .subscribe:hover,
  .subscribe:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .subscribe:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .subscribe:hover,
    .subscribe:focus-visible {
      transform: none;
    }
  }
</style>
