---
/**
 * Writing cell — bottom of column 2.
 *
 * Renders the most recent writing entry: title, date, summary, reading time.
 * Tags rendered as small chips at the bottom.
 */
import Cell from '../ui/Cell.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'writing'>;
  slot?: string;
}

const { entry, slot } = Astro.props;
const { title, date, summary, tags, readingTime } = entry.data;

const dateLabel = date.toLocaleString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const detailHref = `/writing/${entry.id}`;
---

<a
  href={detailHref}
  class="card-link"
  transition:name={`poster-writing-${entry.id}`}
>
  <Cell slot={slot}>
    <p class="text-caption muted">writing</p>

    <h3 class="text-h3 title" transition:name={`poster-writing-${entry.id}-title`}>{title}</h3>

  <p class="meta text-caption muted">
    <span>{dateLabel}</span>
    {readingTime && <span class="dot" aria-hidden="true">·</span>}
    {readingTime && <span>{readingTime} min read</span>}
  </p>

  <p class="summary text-body muted">{summary}</p>

    {
      tags.length > 0 && (
        <ul class="tags" aria-label="tags">
          {tags.slice(0, 3).map((t) => (
            <li class="tag-chip text-caption">{t}</li>
          ))}
        </ul>
      )
    }
  </Cell>
</a>

<style>
  .muted {
    color: var(--text-muted);
  }
  .card-link {
    display: block;
    height: 100%;
    color: inherit;
    text-decoration: none;
    border-radius: var(--radius-lg);
  }
  .card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .title {
    margin: 0;
    color: var(--text);
    /* h3 sized × 2 lines fits the col-2 writing row at typical viewports;
       step to 1 line on short ones. Demoted from h2 → h3 since h2 is a
       structural tier reserved for page sections, not card titles. */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-height: 800px) {
    .title {
      -webkit-line-clamp: 1;
      line-clamp: 1;
    }
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }
  .dot {
    opacity: 0.6;
  }
  .summary {
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-height: 800px) {
    .summary {
      -webkit-line-clamp: 2;
      line-clamp: 2;
    }
  }
  .tags {
    list-style: none;
    padding: 0;
    margin: auto 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }
  /* .tag-chip lives in global.css. */
</style>
