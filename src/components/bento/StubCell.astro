---
/**
 * Stub cell — fills empty slots when a column has more layout slots than
 * we have real content for (e.g. column 3 has 4 project slots, we currently
 * have 1 entry, so 3 stubs render to keep the grid honest).
 *
 * Routes through `<Cell>` (with `as="div"` since stubs aren't articles)
 * so border-radius / padding / sizing stay single-source. The `stub`
 * modifier swaps the surface treatment to a dashed-border on transparent
 * background — distinct enough that empty slots read as intentional
 * placeholders, not failures.
 */
import Cell from '../ui/Cell.astro';

interface Props {
  label?: string;
  slot?: string;
}

const { label = 'more to come', slot } = Astro.props;
---

<Cell as="div" slot={slot} class="stub">
  <span class="text-caption muted center">{label}</span>
</Cell>

<style>
  /* `<Cell class="stub">` keeps the radius + padding contract from Cell.astro;
     these rules only override surface + layout. */
  :global(.bento-cell.stub) {
    background: transparent;
    border: 1px dashed var(--border-strong);
    align-items: center;
    justify-content: center;
  }
  .muted {
    color: var(--text-muted);
  }
  .center {
    text-align: center;
  }
</style>
