---
/**
 * Stub cell — intentional empty slot.
 *
 * All chrome (dashed border, transparent background, centering) lives in
 * `Cell.astro` under the `.bento-cell.stub` modifier so it inherits component
 * scoping. This file just carries the slot identifier and the label.
 */
import Cell from '../ui/Cell.astro';

interface Props {
  label?: string;
  slot?: string;
}

const { label = 'more to come', slot } = Astro.props;
---

<Cell as="div" slot={slot} class="stub">
  <span class="text-caption muted">{label}</span>
</Cell>

<style>
  .muted {
    color: var(--text-muted);
  }
</style>
