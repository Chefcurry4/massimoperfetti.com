---
/**
 * Places cell — bottom of column 4.
 *
 * Phase 6 swap: the hand-drawn placeholder SVG is gone; the cell now uses
 * <WorldMap variant="mini"> (SSR-rendered NaturalEarth1 projection from
 * world-atlas + d3-geo) for accurate country shapes and properly-projected
 * markers. Wraps in <a href="/places"> so click navigates to the full
 * /places page; the link carries transition:name="poster-places" so the
 * View Transitions API morphs the cell into the page.
 */
import Cell from '../ui/Cell.astro';
import type { CollectionEntry } from 'astro:content';
import WorldMap from '../places/WorldMap.astro';

interface Props {
  entries: CollectionEntry<'places'>[];
  slot?: string;
}

const { entries, slot } = Astro.props;

const distinctCountries = new Set(entries.map((e) => e.data.country)).size;
---

<a
  href="/places"
  class="card-link"
  transition:name="poster-places"
  aria-label={`Open all ${entries.length} places visited`}
>
  <Cell slot={slot} class="places-cell">
    <header class="head">
      <p class="text-caption muted">places</p>
      <p class="count text-h3">
        {entries.length}<span class="unit text-small muted"> visited</span>
      </p>
    </header>

    <div class="map-wrap">
      <WorldMap entries={entries} variant="mini" />
    </div>

    <p class="text-caption muted footnote">
      {distinctCountries} {distinctCountries === 1 ? 'country' : 'countries'}
    </p>
  </Cell>
</a>

<style>
  .muted {
    color: var(--text-muted);
  }
  .card-link {
    display: block;
    height: 100%;
    color: inherit;
    text-decoration: none;
    border-radius: var(--radius-lg);
  }
  .card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .places-cell {
    gap: var(--space-3);
  }
  .head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-2);
  }
  .count {
    margin: 0;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 500;
    line-height: 1;
  }
  .unit {
    text-transform: none;
    letter-spacing: 0;
  }

  .map-wrap {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Cap so head + map + 2-item recent list fit the col-4 bottom row at
       viewport heights down to ~720dvh. */
    max-height: 200px;
  }
  @media (max-height: 800px) {
    .map-wrap {
      max-height: 160px;
    }
  }

  .footnote {
    margin: 0;
  }
</style>
