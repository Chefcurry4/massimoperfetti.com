---
/**
 * Places cell — bottom of column 4.
 *
 * Phase 2 placeholder: simplified inline SVG world. ~10 polygon vertices per
 * continent; recognizable, not accurate. Equirectangular projection on a
 * 360×180 viewBox (1 unit per degree) so we can place the city dots with
 * straightforward `x = lng + 180`, `y = 90 - lat`.
 *
 * Phase 6 swaps the SVG for an interactive map (likely react-simple-maps
 * or a custom Natural Earth render).
 */
import Cell from '../ui/Cell.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  entries: CollectionEntry<'places'>[];
  slot?: string;
}

const { entries, slot } = Astro.props;

interface PlotPoint {
  readonly id: string;
  readonly x: number;
  readonly y: number;
  readonly city: string;
  readonly country: string;
}

const dots: PlotPoint[] = entries.map((e) => ({
  id: e.id,
  x: e.data.coordinates.lng + 180,
  y: 90 - e.data.coordinates.lat,
  city: e.data.city,
  country: e.data.country,
}));
---

<Cell slot={slot} class="places-cell">
  <header class="head">
    <p class="text-caption muted">places</p>
    <p class="count text-h3">{entries.length}<span class="unit text-small muted"> visited</span></p>
  </header>

  <div class="map-wrap">
    <svg
      class="world"
      viewBox="0 0 360 180"
      preserveAspectRatio="xMidYMid meet"
      role="img"
      aria-label={`World map showing ${entries.length} place(s) visited`}
    >
      {/* Continent silhouettes — deliberately low-fidelity placeholders. */}
      <g class="land">
        {/* North America */}
        <path
          d="M22,32 L60,22 L120,22 L150,30 L155,50 L120,72 L95,84 L70,82 L52,72 L32,68 L22,52 Z"
        />
        {/* Greenland */}
        <path d="M150,18 L172,16 L178,32 L168,42 L148,38 Z" />
        {/* Central America */}
        <path d="M80,82 L95,86 L100,100 L88,98 L82,90 Z" />
        {/* South America */}
        <path d="M105,98 L130,96 L145,108 L138,138 L120,150 L108,140 L102,118 Z" />
        {/* Africa */}
        <path
          d="M168,58 L210,54 L228,64 L232,82 L222,108 L208,128 L196,132 L186,118 L172,96 L168,76 Z"
        />
        {/* Europe */}
        <path d="M170,42 L190,38 L208,42 L210,54 L196,60 L176,58 L168,52 Z" />
        {/* Middle East */}
        <path d="M210,54 L232,56 L240,68 L232,80 L218,76 L212,66 Z" />
        {/* Eurasia main mass */}
        <path
          d="M210,30 L280,18 L335,22 L348,38 L340,52 L300,58 L268,52 L240,52 L218,46 Z"
        />
        {/* India */}
        <path d="M252,62 L268,62 L266,86 L256,84 L252,72 Z" />
        {/* Southeast Asia */}
        <path d="M278,70 L302,66 L312,82 L298,90 L284,84 Z" />
        {/* China-Korea-Japan stub */}
        <path d="M300,40 L325,42 L330,58 L312,62 L302,52 Z" />
        {/* Australia */}
        <path d="M295,118 L335,118 L342,138 L312,142 L295,134 Z" />
        {/* Antarctica band */}
        <path d="M0,170 L360,170 L360,180 L0,180 Z" />
      </g>

      {/* Equator + prime meridian guides — very faint */}
      <line class="guide" x1="0" y1="90" x2="360" y2="90" />
      <line class="guide" x1="180" y1="0" x2="180" y2="180" />

      {/* City dots */}
      {
        dots.map((d) => (
          <g class="pin" transform={`translate(${d.x} ${d.y})`}>
            <circle class="pin-halo" r="3.5" />
            <circle class="pin-dot" r="1.6" />
          </g>
        ))
      }
    </svg>
  </div>

  {
    entries.length > 0 && (
      <ul class="recent" aria-label="recent places">
        {entries.slice(0, 3).map((e) => (
          <li class="recent-item text-small">
            <span class="city">{e.data.city}</span>
            <span class="country muted">{e.data.country}</span>
          </li>
        ))}
      </ul>
    )
  }
</Cell>

<style>
  .muted {
    color: var(--text-muted);
  }
  .places-cell {
    gap: 0.6rem;
  }
  .head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
  }
  .count {
    margin: 0;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 500;
    line-height: 1;
  }
  .unit {
    text-transform: none;
    letter-spacing: 0;
  }

  .map-wrap {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .world {
    /* Cap at 240px so the map doesn't crowd the recent-places list below
       at the col-4 bottom-row height. */
    width: 100%;
    height: 100%;
    max-height: 240px;
  }
  .land path {
    fill: var(--text-muted);
    fill-opacity: 0.18;
    stroke: var(--text-muted);
    stroke-opacity: 0.35;
    stroke-width: 0.4;
    stroke-linejoin: round;
  }
  .guide {
    stroke: var(--border);
    stroke-width: 0.3;
    stroke-dasharray: 2 3;
  }
  .pin-halo {
    fill: var(--accent);
    fill-opacity: 0.18;
  }
  .pin-dot {
    fill: var(--accent);
  }

  .recent {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .recent-item {
    display: flex;
    justify-content: space-between;
    gap: 0.5rem;
    padding-top: 0.3rem;
    border-top: 1px solid var(--border);
  }
  .city {
    color: var(--text);
  }
  .country {
    text-align: right;
  }
</style>
