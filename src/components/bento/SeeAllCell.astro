---
/**
 * "See all projects" CTA — the third tile in column 3's bottom row.
 *
 * Phase 4: anchor pointing at /projects index page. Hover lift comes from
 * `.bento-cell` in Cell.astro; the accent tint on the count + arrow on
 * hover is the local treatment.
 */
import Cell from '../ui/Cell.astro';

interface Props {
  count: number;
  slot?: string;
}

const { count, slot } = Astro.props;
---

<a href="/projects" class="card-link">
  <Cell glass slot={slot} class="see-all">
    <p class="text-caption muted">all projects</p>
    <p class="num">{count}</p>
    <p class="text-small muted">in total</p>

    <span class="cta text-h3" aria-hidden="true">→</span>
  </Cell>
</a>

<style>
  .muted {
    color: var(--text-muted);
  }
  .card-link {
    display: block;
    height: 100%;
    color: inherit;
    text-decoration: none;
    border-radius: var(--radius-lg);
  }
  .card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .see-all {
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-1);
    cursor: pointer;
  }

  .num {
    /* Decorative-display number; same justification as ProjectsCell.cover-initial. */
    margin: 0;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(40px, 6vw, 56px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--text);
    transition: color var(--duration-normal) var(--ease-out-expo);
  }
  .cta {
    /* Sizing comes from .text-h3 (sans 600, 20px) — replaces the 18px
       escape that previously bypassed the type scale. */
    margin-top: auto;
    align-self: flex-end;
    color: var(--text-muted);
    transition: color var(--duration-normal) var(--ease-out-expo);
  }

  /* Hover/focus tints fire off the anchor so keyboard users see the same
     accent shift as mouse users. */
  .card-link:hover .num,
  .card-link:focus-visible .num,
  .card-link:hover .cta,
  .card-link:focus-visible .cta {
    color: var(--accent);
  }
</style>
