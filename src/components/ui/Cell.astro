---
/**
 * Bento cell primitive. Every wall cell wraps in this — same chrome,
 * same padding rhythm, same border radius.
 *
 * Pass `glass` for liquid-glass surfaces (used selectively per CLAUDE.md
 * §Liquid glass — about, see-all CTA). Pass `class` to extend with a
 * cell-slot identifier so mobile `order:` rules can grab it.
 *
 * The hover-lift rule lives here so every cell gets the same affordance.
 * `.bento-cell.stub` is the "intentional empty slot" modifier, also styled
 * here so it picks up component scoping (avoids specificity ties with
 * `:global` overrides defined elsewhere).
 *
 * `min-width: 0` matters: without it, long children blow out CSS-grid tracks.
 */

interface Props {
  glass?: boolean;
  class?: string;
  /** Slot identifier for mobile order rules (e.g. "cell-about", "cell-project-1"). */
  slot?: string;
  /** Element override — defaults to <article>. */
  as?: 'article' | 'section' | 'div';
}

const { glass = false, class: extra = '', slot, as: Tag = 'article' } = Astro.props;
const classes = [
  'bento-cell',
  glass ? 'glass' : '',
  slot ?? '',
  extra,
]
  .filter(Boolean)
  .join(' ');
---

<Tag class={classes}>
  <slot />
</Tag>

<style>
  .bento-cell {
    /* Compact padding + gap — the wall is now a central strip with a
       hard height ceiling, so cells need to fit content inside a smaller
       envelope than they did when the wall filled the viewport. */
    padding: clamp(var(--space-3), 1.5vw, var(--space-4));
    border-radius: var(--radius-lg);
    background: var(--surface);
    border: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    height: 100%;
    min-width: 0;
    overflow: hidden;
  }

  /* `.glass` is defined globally in styles/global.css; redeclaring background
     here would override it, so we only swap the base background away. */
  .bento-cell.glass {
    background: var(--surface-glass);
  }

  /*
   * No hover or focus-within paint state on bento cells — every prior
   * variant of the affordance (translateY lift, then border+shadow swap,
   * then border+shadow swap with pointer-events suppressed during scroll)
   * caused a visible cascade as the wall scrolled past the cursor. The
   * cells are entirely static. Interaction feedback is handled by the
   * inner `<a class="card-link">` (cursor: pointer) and the cell's
   * focus-visible outline at the link level.
   */

  /*
   * Stub modifier — empty slots styled as dashed-border placeholders.
   * Lives here (rather than in StubCell.astro) so the data-astro-cid
   * scoping wins specificity against any global override.
   */
  .bento-cell.stub {
    background: transparent;
    border: 1px dashed var(--border-strong);
    align-items: center;
    justify-content: center;
    box-shadow: none;
  }
</style>
