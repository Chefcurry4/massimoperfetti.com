---
/**
 * Persistent sidebar.
 *
 * - Desktop (>= 1024px): fixed left, 280px wide, glass surface, full
 *   viewport height (minus the page inset). Always visible.
 * - Mobile  (<  1024px): pinned to the bottom of the viewport. The
 *   collapsed state shows a 72px-tall peek row containing the Identity
 *   block (avatar + name + role) plus a grip handle, so a visitor can
 *   read who's-who without expanding. Tap the row or the handle to expand
 *   into a sheet that fills the lower 80% of the viewport. Background
 *   scrim closes it.
 *
 * `transition:persist="sidebar"` keeps the entire <aside> mounted across
 * Astro View Transitions (Phase 4 morphs and Phase 5 detail-page navigation
 * will rely on this — Spotify keeps playing, theme toggle state preserves).
 */
import Identity from './Identity.astro';
import NowSnippet from './NowSnippet.astro';
import ContactsCluster from './ContactsCluster.astro';
import SpotifyWidget from './SpotifyWidget.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';
---

<aside
  class="sidebar glass"
  transition:persist="sidebar"
  aria-label="Site navigation and identity"
>
  {/* Mobile-only peek row — Identity stays visible when the drawer is
      collapsed, so the strip reads as a person, not as decoration. On
      desktop this row is just laid out in normal flow above the rule. */}
  <div class="peek">
    <Identity />
    <button
      type="button"
      class="drawer-toggle"
      data-drawer-toggle
      aria-label="Toggle sidebar drawer"
      aria-expanded="false"
      aria-controls="sidebar-content"
    >
      <span class="grip" aria-hidden="true"></span>
    </button>
  </div>

  <div id="sidebar-content" class="content">
    <hr class="rule" />
    <NowSnippet />

    <hr class="rule" />
    <ContactsCluster />

    <hr class="rule" />
    <SpotifyWidget />

    <div class="footer">
      <ThemeToggle />
    </div>
  </div>
</aside>

{/* Mobile scrim — clicking it closes the drawer. */}
<div class="drawer-scrim" data-drawer-scrim aria-hidden="true"></div>

<style>
  /* === Desktop (>= 1024px) ============================================== */
  .sidebar {
    position: fixed;
    top: var(--wall-inset);
    bottom: var(--wall-inset);
    left: var(--wall-inset);
    width: var(--sidebar-width);
    z-index: 40;
    border-radius: 18px;
    padding: clamp(16px, 1.5vw, 24px);
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: thin;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .peek {
    /* On desktop the peek row is just a normal block — Identity above the
       first rule. The drawer-toggle button is hidden via the rule below. */
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .peek :global(.identity) {
    flex: 1 1 auto;
    min-width: 0;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1 1 auto;
  }

  .rule {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0;
  }

  .footer {
    margin-top: auto;
    padding-top: 0.5rem;
    display: flex;
    justify-content: flex-end;
  }

  /* The drag handle is desktop-hidden; on desktop the sidebar has no
     toggle UI, it's always visible. */
  .drawer-toggle {
    display: none;
  }
  .drawer-scrim {
    display: none;
  }

  /* === Mobile (< 1024px) — bottom drawer ============================== */
  @media (max-width: 1023.98px) {
    .sidebar {
      /* Pinned to bottom. Collapsed state = peek row only (~72px); expanded
         = up to 80dvh, scrollable inside. The transition runs on max-height
         so the closing animation doesn't snap. */
      top: auto;
      bottom: 0;
      left: 0;
      right: 0;
      width: 100%;
      max-height: 72px;
      height: auto;
      gap: 0;
      border-radius: 18px 18px 0 0;
      padding: 8px clamp(16px, 4vw, 20px) max(env(safe-area-inset-bottom), 12px);
      transition: max-height var(--duration-normal) var(--ease-out-expo);
    }
    .sidebar.open {
      max-height: 80dvh;
      overflow-y: auto;
    }

    .peek {
      flex-direction: column;
      gap: 0;
      align-items: stretch;
    }

    .drawer-toggle {
      display: flex;
      width: 100%;
      /* min 44px tall so the touch target meets iOS HIG / WCAG 2.5.5 */
      min-height: 24px;
      padding: 8px 0;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      cursor: pointer;
      flex-shrink: 0;
      order: -1; /* handle above the identity row */
    }
    .drawer-toggle:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
      border-radius: 4px;
    }
    .grip {
      display: block;
      width: 36px;
      height: 4px;
      border-radius: 4px;
      background: var(--border-strong);
      transition: background var(--duration-fast) var(--ease-out-expo);
    }
    .drawer-toggle:hover .grip,
    .drawer-toggle:focus-visible .grip {
      background: var(--text-muted);
    }

    .content {
      /* Hidden when collapsed; faded in when open. Identity still visible
         in `.peek` above this. */
      opacity: 0;
      pointer-events: none;
      max-height: 0;
      overflow: hidden;
      transition:
        opacity var(--duration-normal) var(--ease-out-expo),
        max-height var(--duration-normal) var(--ease-out-expo);
    }
    .sidebar.open .content {
      opacity: 1;
      pointer-events: auto;
      max-height: none;
      overflow: visible;
    }

    .drawer-scrim {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--duration-normal) var(--ease-out-expo);
      z-index: 39;
    }
    .drawer-scrim.visible {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>

<script>
  /**
   * Drawer toggle for mobile bottom sheet.
   *
   * Listener management uses AbortController so we can guarantee the
   * previous binding is fully torn down before the next page-load re-binds.
   * Without this, the persisted `<aside>` would accumulate listeners on
   * every navigation (transition:persist preserves the DOM node, not its
   * listeners — Astro re-runs scripts on each swap).
   *
   * Body-scroll lock preserves position via `position: fixed; top: -y`,
   * restored on close so the page doesn't snap to the top.
   */
  let abortController: AbortController | null = null;
  let lockedScrollY = 0;

  function lockBodyScroll() {
    lockedScrollY = window.scrollY;
    document.body.style.position = 'fixed';
    document.body.style.top = `-${lockedScrollY}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.classList.add('drawer-open');
  }

  function unlockBodyScroll() {
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    document.body.classList.remove('drawer-open');
    window.scrollTo(0, lockedScrollY);
  }

  function bindDrawer() {
    const sidebar = document.querySelector<HTMLElement>('.sidebar');
    const toggle = document.querySelector<HTMLButtonElement>('[data-drawer-toggle]');
    const scrim = document.querySelector<HTMLElement>('[data-drawer-scrim]');
    if (!sidebar || !toggle || !scrim) return;

    // Tear down any previous binding before re-attaching.
    abortController?.abort();
    abortController = new AbortController();
    const { signal } = abortController;

    const setOpen = (open: boolean) => {
      const isOpen = sidebar.classList.contains('open');
      if (open === isOpen) return;
      sidebar.classList.toggle('open', open);
      scrim.classList.toggle('visible', open);
      toggle.setAttribute('aria-expanded', String(open));
      if (open) lockBodyScroll();
      else unlockBodyScroll();
    };

    toggle.addEventListener(
      'click',
      () => setOpen(!sidebar.classList.contains('open')),
      { signal },
    );
    scrim.addEventListener('click', () => setOpen(false), { signal });
    document.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape' && sidebar.classList.contains('open')) {
          setOpen(false);
        }
      },
      { signal },
    );
  }

  bindDrawer();
  document.addEventListener('astro:page-load', bindDrawer);
</script>
