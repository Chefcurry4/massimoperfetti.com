---
/**
 * Persistent sidebar.
 *
 * Desktop (≥ 1024px) — rail / panel, collapsed by default.
 *   Collapsed (rail, 64px): only the avatar + a vertical accent bar +
 *     the theme toggle are visible. Reads as a thin column on the left edge.
 *   Expanded (panel, 280px): full content (Identity, Now, Contacts,
 *     Spotify, Theme toggle).
 *   Triggers:
 *     - Click anywhere on the sidebar → expand.
 *     - Mouseleave → schedule collapse after 1s (cancelled by mouseenter).
 *     - ESC key → collapse immediately.
 *   The wall + /book anchor to the collapsed (64px) width and never reflow.
 *   The expanded sidebar sits at z-index 40 with a soft shadow so it floats
 *   over the leftmost edge of the wall while open.
 *
 * Mobile (< 1024px) — bottom drawer with Identity peek (unchanged).
 *
 * `transition:persist="sidebar"` keeps the entire <aside> mounted across
 * Astro View Transitions. Listener teardown via AbortController; body
 * scroll lock preserves window.scrollY.
 */
import Identity from './Identity.astro';
import NowSnippet from './NowSnippet.astro';
import ContactsCluster from './ContactsCluster.astro';
import SpotifyWidget from './SpotifyWidget.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';
---

<aside
  class="sidebar glass"
  data-sidebar
  transition:persist="sidebar"
  aria-label="Site navigation and identity"
>
  {/* Mobile-only peek row — Identity stays visible in the collapsed mobile
      drawer. Desktop hides everything except the avatar via .rail rules. */}
  <div class="peek">
    <Identity />
    <button
      type="button"
      class="drawer-toggle"
      data-drawer-toggle
      aria-label="Toggle sidebar drawer"
      aria-expanded="false"
      aria-controls="sidebar-content"
    >
      <span class="grip" aria-hidden="true"></span>
    </button>
  </div>

  <div id="sidebar-content" class="content">
    <hr class="rule" />
    <NowSnippet />

    <hr class="rule" />
    <ContactsCluster />

    <hr class="rule" />
    <SpotifyWidget />

    <div class="footer">
      <ThemeToggle />
    </div>
  </div>
</aside>

{/* Mobile scrim — clicking it closes the drawer. */}
<div class="drawer-scrim" data-drawer-scrim aria-hidden="true"></div>

<style>
  /* === Desktop (>= 1024px) ============================================== */
  .sidebar {
    position: fixed;
    top: var(--wall-inset);
    bottom: var(--wall-inset);
    left: var(--wall-inset);
    width: var(--sidebar-rail);
    z-index: 40;
    border-radius: 18px;
    padding: clamp(12px, 1vw, 16px);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    /* Tighter gap so the expanded panel fits common laptop viewports
       (720-800dvh) without internal scroll. Spotify section flex-fills
       what's left. */
    gap: 0.75rem;
    cursor: pointer;
    transition:
      width var(--duration-normal) var(--ease-out-expo),
      box-shadow var(--duration-normal) var(--ease-out-expo);
  }

  .sidebar.expanded {
    width: var(--sidebar-width);
    /* No internal scroll — content is sized to fit via NowSnippet clamps
       and Spotify flex-fill ceiling. */
    overflow: hidden;
    cursor: default;
    /* Float over the wall when expanded so the user gets the full panel
       without reflowing the layout. */
    box-shadow:
      0 1px 0 0 var(--glass-highlight) inset,
      0 16px 48px var(--glass-shadow);
  }

  /* === Identity collapse behavior ====================================== */
  .peek {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  /* Collapsed: show only the avatar (Identity's 1st child); hide the
     name + role text block. Avatar is centered in the rail. */
  .sidebar:not(.expanded) :global(.identity) {
    grid-template-columns: 1fr;
    justify-content: center;
  }
  .sidebar:not(.expanded) :global(.identity) > :global(.text) {
    display: none;
  }
  .sidebar:not(.expanded) :global(.identity) > :global(.avatar) {
    margin: 0 auto;
  }

  .peek :global(.identity) {
    flex: 1 1 auto;
    min-width: 0;
  }

  /* === Content visibility ============================================== */
  .content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex: 1 1 auto;
    /* `min-height: 0` lets the Spotify section's flex-fill actually shrink
       inside this container — without it, flex children default to their
       content min-size and overflow the sidebar at short viewports. */
    min-height: 0;
    /* Hidden in rail state; faded in when expanded. */
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease-out-expo);
  }
  .sidebar.expanded .content {
    opacity: 1;
    pointer-events: auto;
  }

  .rule {
    border: none;
    border-top: 1px solid var(--border);
    margin: 0;
  }

  .footer {
    margin-top: auto;
    padding-top: 0.5rem;
    display: flex;
    justify-content: flex-end;
  }
  /* Collapsed footer: theme toggle is always visible at the bottom of the
     rail (sits outside `.content` visibility gate by being placed in
     .content for desktop expanded, but we override on the rail). */
  .sidebar:not(.expanded) .footer {
    /* In rail state, content is hidden (opacity 0). Pull the theme toggle
       out of that gate by reaching into the content's footer and re-showing
       it. Achieved here via :not selectors below. */
  }
  /* Reach back into hidden content to re-expose the theme toggle. */
  .sidebar:not(.expanded) .content {
    /* keep content hidden as a block ... */
  }
  .sidebar:not(.expanded) .content > .footer {
    /* ... but float the footer to the bottom of the rail and re-show it. */
    position: absolute;
    bottom: clamp(12px, 1vw, 16px);
    left: 0;
    right: 0;
    justify-content: center;
    opacity: 1;
    pointer-events: auto;
  }
  /* Hide the rule above the footer when collapsed (it'd float weirdly). */
  .sidebar:not(.expanded) .content > :not(.footer) {
    visibility: hidden;
  }

  /* The drawer toggle is mobile-only. */
  .drawer-toggle {
    display: none;
  }
  .drawer-scrim {
    display: none;
  }

  /* === Mobile (< 1024px) — bottom drawer ============================== */
  @media (max-width: 1023.98px) {
    .sidebar {
      /* Pinned to bottom. Collapsed = peek row only (~72px); expanded.open
         = up to 80dvh, scrollable. The mobile collapsed/expanded model is
         independent of the desktop rail/.expanded model. */
      top: auto;
      bottom: 0;
      left: 0;
      right: 0;
      width: 100%;
      max-height: 72px;
      height: auto;
      gap: 0;
      border-radius: 18px 18px 0 0;
      padding: 8px clamp(16px, 4vw, 20px) max(env(safe-area-inset-bottom), 12px);
      cursor: default;
      transition: max-height var(--duration-normal) var(--ease-out-expo);
    }
    .sidebar.open {
      max-height: 80dvh;
      overflow-y: auto;
    }
    /* On mobile, the desktop `.expanded` class is irrelevant; reset its
       width override so it doesn't fight the full-width drawer. */
    .sidebar.expanded {
      width: 100%;
      box-shadow: none;
    }

    .peek {
      flex-direction: column;
      gap: 0;
      align-items: stretch;
    }
    /* Re-show name + role on mobile (always — peek row is the identity card). */
    .sidebar:not(.expanded) :global(.identity) {
      display: grid;
      grid-template-columns: 48px 1fr;
      justify-content: start;
    }
    .sidebar:not(.expanded) :global(.identity) > :global(.text) {
      display: flex;
    }

    .drawer-toggle {
      display: flex;
      width: 100%;
      min-height: 24px;
      padding: 8px 0;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      cursor: pointer;
      flex-shrink: 0;
      order: -1;
    }
    .drawer-toggle:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
      border-radius: 4px;
    }
    .grip {
      display: block;
      width: 36px;
      height: 4px;
      border-radius: 4px;
      background: var(--border-strong);
      transition: background var(--duration-fast) var(--ease-out-expo);
    }
    .drawer-toggle:hover .grip,
    .drawer-toggle:focus-visible .grip {
      background: var(--text-muted);
    }

    .content {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition:
        opacity var(--duration-normal) var(--ease-out-expo),
        max-height var(--duration-normal) var(--ease-out-expo);
    }
    /* Mobile content reveal is gated on .open, NOT .expanded. */
    .sidebar.open .content {
      opacity: 1;
      pointer-events: auto;
      max-height: none;
      overflow: visible;
    }
    /* Reset the desktop rail-content tricks on mobile. */
    .sidebar:not(.expanded) .content > :not(.footer),
    .sidebar:not(.open) .content > :not(.footer) {
      visibility: visible;
    }
    .sidebar:not(.expanded) .content > .footer,
    .sidebar:not(.open) .content > .footer {
      position: static;
    }

    .drawer-scrim {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.5);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--duration-normal) var(--ease-out-expo);
      z-index: 39;
    }
    .drawer-scrim.visible {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>

<script>
  /**
   * Sidebar interaction:
   *   Desktop — click expands; mouseleave starts a 1s timer to collapse,
   *             cancelled by mouseenter; ESC collapses immediately.
   *   Mobile  — drawer toggle button + scrim (unchanged from prior phase).
   *
   * AbortController + module-scope timer ref ensure clean teardown across
   * astro:page-load re-binds (sidebar DOM persists via transition:persist
   * but Astro re-runs scripts on each swap).
   */
  const COLLAPSE_DELAY_MS = 1000;
  const MOBILE_BREAKPOINT = 1024;

  let abortController: AbortController | null = null;
  let collapseTimer: ReturnType<typeof setTimeout> | null = null;
  let lockedScrollY = 0;

  function isDesktop(): boolean {
    return window.matchMedia(`(min-width: ${MOBILE_BREAKPOINT}px)`).matches;
  }

  function lockBodyScroll() {
    lockedScrollY = window.scrollY;
    document.body.style.position = 'fixed';
    document.body.style.top = `-${lockedScrollY}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.classList.add('drawer-open');
  }
  function unlockBodyScroll() {
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    document.body.classList.remove('drawer-open');
    window.scrollTo(0, lockedScrollY);
  }

  function bindSidebar() {
    const sidebar = document.querySelector<HTMLElement>('[data-sidebar]');
    const toggle = document.querySelector<HTMLButtonElement>('[data-drawer-toggle]');
    const scrim = document.querySelector<HTMLElement>('[data-drawer-scrim]');
    if (!sidebar) return;

    abortController?.abort();
    abortController = new AbortController();
    const { signal } = abortController;

    // ----- Desktop: rail / panel ---------------------------------------
    const cancelCollapse = () => {
      if (collapseTimer !== null) {
        clearTimeout(collapseTimer);
        collapseTimer = null;
      }
    };
    const scheduleCollapse = () => {
      cancelCollapse();
      collapseTimer = setTimeout(() => {
        sidebar.classList.remove('expanded');
        collapseTimer = null;
      }, COLLAPSE_DELAY_MS);
    };
    const expand = () => {
      cancelCollapse();
      sidebar.classList.add('expanded');
    };
    const collapseNow = () => {
      cancelCollapse();
      sidebar.classList.remove('expanded');
    };

    // Click anywhere on the sidebar expands. Anchors / buttons inside still
    // work because click bubbles up after their default action runs.
    sidebar.addEventListener(
      'click',
      () => {
        if (isDesktop()) expand();
      },
      { signal },
    );
    sidebar.addEventListener('mouseenter', () => {
      if (isDesktop()) cancelCollapse();
    }, { signal });
    sidebar.addEventListener('mouseleave', () => {
      if (isDesktop() && sidebar.classList.contains('expanded')) {
        scheduleCollapse();
      }
    }, { signal });

    document.addEventListener(
      'keydown',
      (e) => {
        if (e.key !== 'Escape') return;
        if (isDesktop() && sidebar.classList.contains('expanded')) {
          collapseNow();
        }
      },
      { signal },
    );

    // ----- Mobile: bottom drawer (unchanged) ---------------------------
    if (toggle && scrim) {
      const setOpen = (open: boolean) => {
        const isOpen = sidebar.classList.contains('open');
        if (open === isOpen) return;
        sidebar.classList.toggle('open', open);
        scrim.classList.toggle('visible', open);
        toggle.setAttribute('aria-expanded', String(open));
        if (open) lockBodyScroll();
        else unlockBodyScroll();
      };

      toggle.addEventListener(
        'click',
        (e) => {
          // On desktop the toggle button is hidden via CSS, but guard anyway.
          if (isDesktop()) return;
          // Don't bubble up to the sidebar's own click-to-expand.
          e.stopPropagation();
          setOpen(!sidebar.classList.contains('open'));
        },
        { signal },
      );
      scrim.addEventListener('click', () => setOpen(false), { signal });
      document.addEventListener(
        'keydown',
        (e) => {
          if (e.key === 'Escape' && sidebar.classList.contains('open')) {
            setOpen(false);
          }
        },
        { signal },
      );
    }
  }

  bindSidebar();
  document.addEventListener('astro:page-load', bindSidebar);
</script>
