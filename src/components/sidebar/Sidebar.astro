---
/**
 * Persistent sidebar.
 *
 * Desktop (≥ 1024px) — rail / panel, collapsed by default.
 *   Collapsed (rail, 64px): avatar + a vertical accent edge + a discoverable
 *     chevron trigger + the theme toggle. Reads as a thin column on the
 *     left edge with one obvious "expand" affordance.
 *   Expanded (panel, 280px): full content (Identity, Now, Contacts + Book,
 *     Spotify, Theme toggle).
 *   Triggers:
 *     - Click the chevron (or anywhere on the rail) → expand.
 *     - Click the chevron when expanded → collapse immediately.
 *     - Mouseleave → schedule collapse after 1s (cancelled by mouseenter).
 *     - ESC key → collapse immediately.
 *   The wall + /book anchor to the collapsed (64px) width and never reflow.
 *   The expanded sidebar sits at z-index var(--z-sidebar) with a soft shadow
 *   so it floats over the leftmost edge of the wall while open.
 *
 * Mobile (< 1024px) — bottom drawer with Identity peek (unchanged).
 *
 * `transition:persist="sidebar"` keeps the entire <aside> mounted across
 * Astro View Transitions. Listener teardown via AbortController; body
 * scroll lock preserves window.scrollY.
 *
 * Spacing rhythm uses semantic --space-* tokens throughout. Section
 * dividers are integrated into each section (border-top + padding-top via
 * the `.content > * + *` rule) instead of standalone <hr> elements — gives
 * each section its own breathing room rather than a flat hairline.
 */
import Identity from './Identity.astro';
import NowSnippet from './NowSnippet.astro';
import ContactsCluster from './ContactsCluster.astro';
import SpotifyWidget from './SpotifyWidget.astro';
import ThemeToggle from '../ui/ThemeToggle.astro';
---

<aside
  class="sidebar glass"
  data-sidebar
  transition:persist="sidebar"
  aria-label="Site navigation and identity"
>
  {/* Mobile-only peek row — Identity stays visible in the collapsed mobile
      drawer. Desktop hides everything except the avatar via .rail rules. */}
  <div class="peek">
    <Identity />
    <button
      type="button"
      class="drawer-toggle"
      data-drawer-toggle
      aria-label="Toggle sidebar drawer"
      aria-expanded="false"
      aria-controls="sidebar-content"
    >
      <span class="grip" aria-hidden="true"></span>
    </button>
  </div>

  <div id="sidebar-content" class="content">
    <NowSnippet />
    <ContactsCluster />
    <SpotifyWidget />

    <div class="footer">
      <ThemeToggle />
    </div>
  </div>

  {/* Desktop-only chevron — the discoverable expand/collapse affordance.
      Sits at bottom-center of the rail when collapsed; rotates 180° and
      moves to the right edge of the panel when expanded. Click toggles
      .expanded. */}
  <button
    type="button"
    class="rail-chevron"
    data-rail-chevron
    aria-label="Expand sidebar"
    aria-expanded="false"
    aria-controls="sidebar-content"
  >
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M9 6l6 6-6 6" />
    </svg>
  </button>
</aside>

{/* Mobile scrim — clicking it closes the drawer. */}
<div class="drawer-scrim" data-drawer-scrim aria-hidden="true"></div>

<style>
  /* === Desktop (>= 1024px) ============================================== */
  .sidebar {
    position: fixed;
    top: var(--wall-inset);
    bottom: var(--wall-inset);
    left: var(--wall-inset);
    width: var(--sidebar-rail);
    z-index: var(--z-sidebar);
    border-radius: var(--radius-lg);
    padding: var(--space-4) var(--space-3);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    /* Outer rhythm: --space-5 (24px) between top-level pieces (peek, content,
       chevron). Inner rhythm comes from .content's own gap. */
    gap: var(--space-5);
    transition:
      width var(--duration-normal) var(--ease-out-expo),
      box-shadow var(--duration-normal) var(--ease-out-expo);
  }

  /* Vertical accent edge on the right of the rail — subtle signal that the
     column is interactive. Fades out when expanded. */
  .sidebar::after {
    content: '';
    position: absolute;
    top: 18%;
    bottom: 18%;
    right: -1px;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--accent) 35%,
      var(--accent) 65%,
      transparent
    );
    opacity: 0.32;
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease-out-expo);
  }
  .sidebar.expanded::after {
    opacity: 0;
  }

  .sidebar.expanded {
    width: var(--sidebar-width);
    padding: var(--space-5);
    overflow: hidden;
    /* Float over the wall when expanded so the user gets the full panel
       without reflowing the layout. */
    box-shadow:
      0 1px 0 0 var(--glass-highlight) inset,
      0 16px 48px var(--glass-shadow);
  }

  /* === Identity collapse behavior ====================================== */
  .peek {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }
  /* Collapsed: show only the avatar (Identity's 1st child); hide the
     name + role text block. Avatar is centered in the rail. */
  .sidebar:not(.expanded) :global(.identity) {
    grid-template-columns: 1fr;
    justify-content: center;
  }
  .sidebar:not(.expanded) :global(.identity) > :global(.text) {
    display: none;
  }
  .sidebar:not(.expanded) :global(.identity) > :global(.avatar) {
    margin: 0 auto;
  }

  .peek :global(.identity) {
    flex: 1 1 auto;
    min-width: 0;
  }

  /* === Content visibility ============================================== */
  .content {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    flex: 1 1 auto;
    /* `min-height: 0` lets the Spotify section's flex-fill actually shrink
       inside this container — without it, flex children default to their
       content min-size and overflow the sidebar at short viewports. */
    min-height: 0;
    /* Hidden in rail state; faded in when expanded. */
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--duration-normal) var(--ease-out-expo);
  }
  .sidebar.expanded .content {
    opacity: 1;
    pointer-events: auto;
  }

  /*
   * Section dividers — each section after the first gets a border-top and
   * padding-top so the divider has integrated breathing room. Adjacent-
   * sibling selector means there's no border above the first section
   * (NowSnippet) or above the footer (which is anchored by margin-top: auto).
   * The footer-divider exception sits separately because the chevron may
   * sit between it and the prior section visually.
   */
  .content > * + *:not(.footer) {
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
  }
  .content > .footer {
    margin-top: auto;
    padding-top: var(--space-3);
    display: flex;
    justify-content: flex-end;
  }

  /* Collapsed footer: theme toggle is always visible at the bottom of the
     rail (sits outside `.content` visibility gate by being placed in
     .content for desktop expanded, but we override on the rail). */
  .sidebar:not(.expanded) .content > .footer {
    /* Float the footer to the bottom of the rail and re-show it even though
       .content's opacity is 0 in rail state. */
    position: absolute;
    bottom: var(--space-4);
    left: 0;
    right: 0;
    justify-content: center;
    padding-top: 0;
    opacity: 1;
    pointer-events: auto;
  }
  /* Hide everything else in the content block when collapsed (would float
     visually weirdly behind the chevron). */
  .sidebar:not(.expanded) .content > :not(.footer) {
    visibility: hidden;
  }

  /* === Rail chevron ==================================================== */
  .rail-chevron {
    /* Bottom-center of the rail, sitting above the theme toggle footer.
       Width matches the rail interior; tappable target meets a11y minimum. */
    position: absolute;
    bottom: calc(var(--space-4) + var(--control-h-md) + var(--space-3));
    left: 0;
    right: 0;
    margin: 0 auto;
    width: var(--control-h-sm);
    height: var(--control-h-sm);
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-strong);
    background: transparent;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
      color var(--duration-normal) var(--ease-out-expo),
      border-color var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo),
      background var(--duration-normal) var(--ease-out-expo);
  }
  .rail-chevron:hover {
    color: var(--text);
    border-color: var(--text-muted);
  }
  .rail-chevron:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    color: var(--accent);
    border-color: var(--accent);
  }
  /* When expanded, chevron flips and migrates to top-right of the panel. */
  .sidebar.expanded .rail-chevron {
    bottom: auto;
    top: var(--space-3);
    left: auto;
    right: var(--space-3);
    margin: 0;
    transform: rotate(180deg);
  }

  /* The drawer toggle is mobile-only. */
  .drawer-toggle {
    display: none;
  }
  .drawer-scrim {
    display: none;
  }

  /* === Mobile (< 1024px) — bottom drawer ============================== */
  @media (max-width: 1023.98px) {
    .sidebar {
      /* Pinned to bottom. Collapsed = peek row only (~72px); expanded.open
         = up to 80dvh, scrollable. The mobile collapsed/expanded model is
         independent of the desktop rail/.expanded model. */
      top: auto;
      bottom: 0;
      left: 0;
      right: 0;
      width: 100%;
      max-height: 72px;
      height: auto;
      gap: 0;
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      padding:
        var(--space-2)
        clamp(var(--space-4), 4vw, var(--space-5))
        max(env(safe-area-inset-bottom), var(--space-3));
      cursor: default;
      transition: max-height var(--duration-normal) var(--ease-out-expo);
    }
    .sidebar.open {
      max-height: 80dvh;
      overflow-y: auto;
    }
    /* On mobile, the desktop `.expanded` class is irrelevant; reset its
       width override so it doesn't fight the full-width drawer. */
    .sidebar.expanded {
      width: 100%;
      box-shadow: none;
      padding: var(--space-2)
        clamp(var(--space-4), 4vw, var(--space-5))
        max(env(safe-area-inset-bottom), var(--space-3));
    }
    /* Hide the desktop-only rail chevron + accent edge on mobile. */
    .rail-chevron,
    .sidebar::after {
      display: none;
    }

    .peek {
      flex-direction: column;
      gap: 0;
      align-items: stretch;
    }
    /* Re-show name + role on mobile (always — peek row is the identity card). */
    .sidebar:not(.expanded) :global(.identity) {
      display: grid;
      grid-template-columns: 48px 1fr;
      justify-content: start;
    }
    .sidebar:not(.expanded) :global(.identity) > :global(.text) {
      display: flex;
    }

    .drawer-toggle {
      display: flex;
      width: 100%;
      min-height: 24px;
      padding: var(--space-2) 0;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      cursor: pointer;
      flex-shrink: 0;
      order: -1;
    }
    .drawer-toggle:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
      border-radius: var(--radius-sm);
    }
    .grip {
      display: block;
      width: 36px;
      height: 4px;
      border-radius: var(--radius-sm);
      background: var(--border-strong);
      transition: background var(--duration-fast) var(--ease-out-expo);
    }
    .drawer-toggle:hover .grip,
    .drawer-toggle:focus-visible .grip {
      background: var(--text-muted);
    }

    .content {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition:
        opacity var(--duration-normal) var(--ease-out-expo),
        max-height var(--duration-normal) var(--ease-out-expo);
    }
    /* Mobile content reveal is gated on .open, NOT .expanded. */
    .sidebar.open .content {
      opacity: 1;
      pointer-events: auto;
      max-height: none;
      overflow: visible;
    }
    /* Reset the desktop rail-content tricks on mobile. */
    .sidebar:not(.expanded) .content > :not(.footer),
    .sidebar:not(.open) .content > :not(.footer) {
      visibility: visible;
    }
    .sidebar:not(.expanded) .content > .footer,
    .sidebar:not(.open) .content > .footer {
      position: static;
    }

    .drawer-scrim {
      display: block;
      position: fixed;
      inset: 0;
      background: var(--scrim-modal);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--duration-normal) var(--ease-out-expo);
      z-index: calc(var(--z-sidebar) - 1);
    }
    .drawer-scrim.visible {
      opacity: 1;
      pointer-events: auto;
    }
  }
</style>

<script>
  /**
   * Sidebar interaction:
   *   Desktop — chevron click toggles expand/collapse; click-anywhere on
   *             the rail still expands (cheap discoverability fallback);
   *             mouseleave starts a 1s timer to collapse, cancelled by
   *             mouseenter; ESC collapses immediately.
   *   Mobile  — drawer toggle button + scrim (unchanged from prior phase).
   *
   * AbortController + module-scope timer ref ensure clean teardown across
   * astro:page-load re-binds (sidebar DOM persists via transition:persist
   * but Astro re-runs scripts on each swap).
   */
  const COLLAPSE_DELAY_MS = 1000;
  const MOBILE_BREAKPOINT = 1024;

  let abortController: AbortController | null = null;
  let collapseTimer: ReturnType<typeof setTimeout> | null = null;
  let lockedScrollY = 0;

  function isDesktop(): boolean {
    return window.matchMedia(`(min-width: ${MOBILE_BREAKPOINT}px)`).matches;
  }

  function lockBodyScroll() {
    lockedScrollY = window.scrollY;
    document.body.style.position = 'fixed';
    document.body.style.top = `-${lockedScrollY}px`;
    document.body.style.left = '0';
    document.body.style.right = '0';
    document.body.classList.add('drawer-open');
  }
  function unlockBodyScroll() {
    document.body.style.position = '';
    document.body.style.top = '';
    document.body.style.left = '';
    document.body.style.right = '';
    document.body.classList.remove('drawer-open');
    window.scrollTo(0, lockedScrollY);
  }

  function bindSidebar() {
    const sidebar = document.querySelector<HTMLElement>('[data-sidebar]');
    const chevron = document.querySelector<HTMLButtonElement>('[data-rail-chevron]');
    const toggle = document.querySelector<HTMLButtonElement>('[data-drawer-toggle]');
    const scrim = document.querySelector<HTMLElement>('[data-drawer-scrim]');
    if (!sidebar) return;

    abortController?.abort();
    abortController = new AbortController();
    const { signal } = abortController;

    // ----- Desktop: rail / panel ---------------------------------------
    const cancelCollapse = () => {
      if (collapseTimer !== null) {
        clearTimeout(collapseTimer);
        collapseTimer = null;
      }
    };
    const scheduleCollapse = () => {
      cancelCollapse();
      collapseTimer = setTimeout(() => {
        sidebar.classList.remove('expanded');
        chevron?.setAttribute('aria-expanded', 'false');
        chevron?.setAttribute('aria-label', 'Expand sidebar');
        collapseTimer = null;
      }, COLLAPSE_DELAY_MS);
    };
    const expand = () => {
      cancelCollapse();
      sidebar.classList.add('expanded');
      chevron?.setAttribute('aria-expanded', 'true');
      chevron?.setAttribute('aria-label', 'Collapse sidebar');
    };
    const collapseNow = () => {
      cancelCollapse();
      sidebar.classList.remove('expanded');
      chevron?.setAttribute('aria-expanded', 'false');
      chevron?.setAttribute('aria-label', 'Expand sidebar');
    };

    // Click anywhere on the sidebar expands. Anchors / buttons inside still
    // work because click bubbles up after their default action runs.
    sidebar.addEventListener(
      'click',
      () => {
        if (isDesktop() && !sidebar.classList.contains('expanded')) expand();
      },
      { signal },
    );
    // Chevron toggles. Stop propagation so it can collapse without the
    // sidebar's click-to-expand reopening it on the same click.
    chevron?.addEventListener(
      'click',
      (e) => {
        if (!isDesktop()) return;
        e.stopPropagation();
        if (sidebar.classList.contains('expanded')) collapseNow();
        else expand();
      },
      { signal },
    );
    sidebar.addEventListener('mouseenter', () => {
      if (isDesktop()) cancelCollapse();
    }, { signal });
    sidebar.addEventListener('mouseleave', () => {
      if (isDesktop() && sidebar.classList.contains('expanded')) {
        scheduleCollapse();
      }
    }, { signal });

    document.addEventListener(
      'keydown',
      (e) => {
        if (e.key !== 'Escape') return;
        if (isDesktop() && sidebar.classList.contains('expanded')) {
          collapseNow();
        }
      },
      { signal },
    );

    // ----- Mobile: bottom drawer (unchanged) ---------------------------
    if (toggle && scrim) {
      const setOpen = (open: boolean) => {
        const isOpen = sidebar.classList.contains('open');
        if (open === isOpen) return;
        sidebar.classList.toggle('open', open);
        scrim.classList.toggle('visible', open);
        toggle.setAttribute('aria-expanded', String(open));
        if (open) lockBodyScroll();
        else unlockBodyScroll();
      };

      toggle.addEventListener(
        'click',
        (e) => {
          // On desktop the toggle button is hidden via CSS, but guard anyway.
          if (isDesktop()) return;
          // Don't bubble up to the sidebar's own click-to-expand.
          e.stopPropagation();
          setOpen(!sidebar.classList.contains('open'));
        },
        { signal },
      );
      scrim.addEventListener('click', () => setOpen(false), { signal });
      document.addEventListener(
        'keydown',
        (e) => {
          if (e.key === 'Escape' && sidebar.classList.contains('open')) {
            setOpen(false);
          }
        },
        { signal },
      );
    }
  }

  bindSidebar();
  document.addEventListener('astro:page-load', bindSidebar);
</script>
