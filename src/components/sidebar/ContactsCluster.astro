---
/**
 * Sidebar contacts + book — two related subsections living under a single
 * cluster wrapper so they cohabit visually (no divider between contacts
 * and book) but still read as distinct affordances.
 *
 * Structure:
 *   .cluster
 *     section.contacts  → eyebrow + icon row
 *     section.book      → eyebrow + full-width pill linking to /book
 *     div[popover]      → email-cluster overlay (CSS Anchor Positioned
 *                         relative to the email icon when supported,
 *                         falls back to centered modal in older browsers)
 *
 * Filters to public-audience entries so academic emails (MIT, TU Delft) stay
 * out of the always-visible cluster — they're folded into the email popover
 * instead of crowding the sidebar with three identical envelope icons.
 *
 * Tooltips on icon links use `side="right"` because the sidebar sits at the
 * left edge — tooltips reading outward feel anchored, tooltips reading
 * upward (the default) collide with the previous section's content.
 */
import { contacts, type ContactKind } from '../../data/contacts';
import Tooltip from '../ui/Tooltip.astro';

const iconStrokeWidth = 1.7;

const iconPaths: Record<ContactKind, string> = {
  email: 'M3 6.5h18v11H3zM3.5 7l8.5 6.5L20.5 7',
  github:
    'M9 19c-4 1.4-4-2-6-2.5M15 21v-3.5a3.4 3.4 0 0 0-.9-2.6c3-.3 6-1.5 6-6.5a5 5 0 0 0-1.4-3.5 4.6 4.6 0 0 0-.1-3.5s-1.1-.4-3.6 1.4a12.3 12.3 0 0 0-6.5 0C5.9 1 4.8 1.4 4.8 1.4a4.6 4.6 0 0 0-.1 3.5A5 5 0 0 0 3.3 8.4c0 5 3 6.2 6 6.5A3.4 3.4 0 0 0 8.4 17.5V21',
  linkedin:
    'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2zM4 6.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z',
  x: 'M4 4l16 16M20 4L4 20',
  scholar:
    'M22 10v6M2 10l10-5 10 5-10 5z M6 12v5c3 3 9 3 12 0v-5',
  cv: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8',
  newsletter: 'M4 6h12v10H4zM4 6l6 5 6-5M19 9h3M19 12h3M19 15h3',
  leetcode: 'M9 6L4 12l5 6M15 6l5 6-5 6M14 4l-4 16',
};

const visibleContacts = contacts.filter(
  (c) => (c.audience ?? 'public') === 'public',
);

// Emails partition: collapse to one envelope icon → click opens popover
// listing all addresses (incl. academic ones folded back in).
const emails = contacts.filter((c) => c.kind === 'email');
const nonEmails = visibleContacts.filter((c) => c.kind !== 'email');
const hasMultipleEmails = emails.length > 1;
const primaryEmail = emails[0];
---

<div class="cluster">
  <section class="contacts" aria-label="Contact channels">
    <p class="text-caption muted">contacts</p>
    <ul class="row">
      {/* Email icon: popover trigger if multiple, plain mailto link otherwise. */}
      {primaryEmail && (
        <li>
          <Tooltip label={hasMultipleEmails ? 'Email' : primaryEmail.label} side="right">
            {hasMultipleEmails ? (
              <button
                type="button"
                class="icon-link email-trigger"
                popovertarget="email-popover"
                aria-label={`Email — ${emails.length} addresses`}
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width={iconStrokeWidth}
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={iconPaths.email} />
                </svg>
              </button>
            ) : (
              <a
                class="icon-link"
                href={primaryEmail.url}
                aria-label={`${primaryEmail.label} — ${primaryEmail.handle}`}
              >
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width={iconStrokeWidth}
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d={iconPaths.email} />
                </svg>
              </a>
            )}
          </Tooltip>
        </li>
      )}

      {nonEmails.map((c) => (
        <li>
          <Tooltip label={c.label} side="right">
            <a
              class="icon-link"
              href={c.url}
              aria-label={`${c.label} — ${c.handle}`}
              rel="me noopener"
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width={iconStrokeWidth}
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d={iconPaths[c.kind]} />
              </svg>
            </a>
          </Tooltip>
        </li>
      ))}
    </ul>
  </section>

  <section class="book" aria-label="Book a meeting">
    <p class="text-caption muted">book</p>
    <a class="book-cta text-ui" href="/book" data-astro-prefetch>
      <span>Book a 30-min call</span>
      <svg
        width="12"
        height="12"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M7 17L17 7M9 7h8v8" />
      </svg>
    </a>
  </section>

  {/* Email popover — anchored to the envelope icon via CSS Anchor
      Positioning where supported; falls back to centered modal in browsers
      that don't yet support `anchor-name` (Firefox WIP as of 2026-05). */}
  {hasMultipleEmails && (
    <div id="email-popover" popover="auto" class="email-popover glass">
      <p class="text-caption muted email-popover-head">choose an address</p>
      <ul class="email-list">
        {emails.map((e) => (
          <li class="email-row">
            <span class="email-label text-small">{e.label}</span>
            <a class="email-handle text-mono-small" href={e.url}>{e.handle}</a>
          </li>
        ))}
      </ul>
    </div>
  )}
</div>

<style>
  .muted {
    color: var(--text-muted);
  }
  .cluster {
    /* Holds the contacts + book pair. Internal gap is tighter than the
       sidebar's section rhythm so they read as a related unit. */
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .contacts,
  .book {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* === Contacts row === */
  .row {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--control-h-sm);
    height: var(--control-h-sm);
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-strong);
    color: var(--text);
    background: transparent;
    padding: 0;
    cursor: pointer;
    transition:
      color var(--duration-normal) var(--ease-out-expo),
      border-color var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
  }
  .icon-link:hover,
  .icon-link:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .icon-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  /* Anchor name on the email trigger so the popover can target it. The
     `--email-trigger` name is intentionally specific so we never accidentally
     anchor a different element to it. */
  .email-trigger {
    anchor-name: --email-trigger;
  }

  /*
   * Book a call CTA — full-width pill with accent border. Earns its weight
   * by being the only accent-bordered surface in the sidebar. Uses .text-ui
   * for the type tier (was an ad-hoc 12.5px before Phase A added the class).
   */
  .book-cta {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-pill);
    border: 1px solid var(--accent);
    color: var(--text);
    background: transparent;
    cursor: pointer;
    width: 100%;
    transition:
      color var(--duration-normal) var(--ease-out-expo),
      background var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
  }
  .book-cta:hover,
  .book-cta:focus-visible {
    color: var(--accent);
    background: color-mix(in oklab, var(--accent) 8%, transparent);
    transform: translateY(-1px);
  }
  .book-cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .book-cta svg {
    transition: transform var(--duration-normal) var(--ease-out-expo);
  }
  .book-cta:hover svg,
  .book-cta:focus-visible svg {
    transform: translate(1px, -1px);
  }
</style>

<style is:global>
  /*
   * Email popover — top-layer overlay (HTML Popover API).
   *
   * Default anchored placement: pops UP from the envelope icon (positioned
   * with bottom anchored to the icon's top, with a gap). Falls back to a
   * centered modal when CSS Anchor Positioning isn't supported.
   *
   * The popover element renders in the top layer outside any scoped style
   * boundary, so its rules live in :global. ::backdrop is the dimmed scrim
   * the browser draws behind a `popover="auto"` element when open.
   */
  .email-popover {
    position-anchor: --email-trigger;
    /* Pop above the icon so the list opens upward into the user's gaze.
       In the rail (collapsed sidebar) the icon is near the screen's left
       edge, so anchoring left-aligned with the icon keeps the popover
       inside the viewport even at narrow widths. */
    bottom: anchor(top);
    left: anchor(left);
    margin: 0 0 var(--space-3) 0;
    padding: var(--space-4) var(--space-4);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    min-width: min(320px, 90vw);
    max-width: 420px;
    color: var(--text);
  }
  .email-popover::backdrop {
    background: var(--scrim-modal);
    backdrop-filter: blur(2px);
  }
  .email-popover-head {
    color: var(--text-muted);
    margin: 0 0 var(--space-3) 0;
  }
  .email-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .email-row {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: baseline;
    gap: var(--space-3);
    padding: var(--space-2) 0;
    border-top: 1px solid var(--border);
  }
  .email-row:first-child {
    border-top: none;
  }
  .email-label {
    color: var(--text);
  }
  .email-handle {
    color: var(--text-muted);
    text-align: right;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    transition: color var(--duration-normal) var(--ease-out-expo);
  }
  .email-handle:hover,
  .email-handle:focus-visible {
    color: var(--accent);
  }

  /*
   * Fallback for browsers without CSS Anchor Positioning (Firefox as of
   * 2026-05): center the popover in the viewport. The browser handles
   * dismissal regardless. We intentionally use `:not(@supports)` flow via
   * a feature query so supported browsers ignore this.
   */
  @supports not (anchor-name: --x) {
    .email-popover {
      position-anchor: none;
      inset: 0;
      margin: auto;
      bottom: auto;
      left: auto;
    }
  }
</style>
