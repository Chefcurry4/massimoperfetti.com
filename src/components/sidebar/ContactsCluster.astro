---
/**
 * Sidebar contacts — icons-only row with elegant tooltip labels on hover,
 * a click-to-reveal popover for the multiple email addresses, and a
 * "Book a 30-min call" CTA bottom-right that points at Cal.com.
 *
 * Filters to public-audience entries so academic emails (MIT, TU Delft) stay
 * out of the always-visible cluster — they're folded into the email popover
 * instead of crowding the sidebar with three identical envelope icons.
 *
 * Email popover uses the native HTML Popover API (`popover` attribute +
 * `popovertarget`). Click-outside-to-close and ESC are handled by the
 * browser; no JS required. If only one email is present the envelope
 * degrades to a plain mailto anchor.
 *
 * Icon paths are duplicated from the (now retired) bento ContactsCell. If a
 * third surface ever needs them they should be hoisted to a shared module.
 */
import { contacts, type ContactKind } from '../../data/contacts';
import Tooltip from '../ui/Tooltip.astro';

const iconStrokeWidth = 1.7;

const iconPaths: Record<ContactKind, string> = {
  email: 'M3 6.5h18v11H3zM3.5 7l8.5 6.5L20.5 7',
  github:
    'M9 19c-4 1.4-4-2-6-2.5M15 21v-3.5a3.4 3.4 0 0 0-.9-2.6c3-.3 6-1.5 6-6.5a5 5 0 0 0-1.4-3.5 4.6 4.6 0 0 0-.1-3.5s-1.1-.4-3.6 1.4a12.3 12.3 0 0 0-6.5 0C5.9 1 4.8 1.4 4.8 1.4a4.6 4.6 0 0 0-.1 3.5A5 5 0 0 0 3.3 8.4c0 5 3 6.2 6 6.5A3.4 3.4 0 0 0 8.4 17.5V21',
  linkedin:
    'M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2zM4 6.5a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z',
  x: 'M4 4l16 16M20 4L4 20',
  scholar:
    'M22 10v6M2 10l10-5 10 5-10 5z M6 12v5c3 3 9 3 12 0v-5',
  cv: 'M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8zM14 2v6h6M16 13H8M16 17H8M10 9H8',
  newsletter: 'M4 6h12v10H4zM4 6l6 5 6-5M19 9h3M19 12h3M19 15h3',
  leetcode: 'M9 6L4 12l5 6M15 6l5 6-5 6M14 4l-4 16',
};

const visibleContacts = contacts.filter(
  (c) => (c.audience ?? 'public') === 'public',
);

// Partition emails from everything else so the email cluster collapses to
// a single envelope icon (with popover) instead of stacking duplicates.
// Academic emails (audience: 'academic') are intentionally folded back in
// here so the popover lists ALL three addresses, not just the public one.
const emails = contacts.filter((c) => c.kind === 'email');
const nonEmails = visibleContacts.filter((c) => c.kind !== 'email');
const hasMultipleEmails = emails.length > 1;
const primaryEmail = emails[0];
---

<section class="contacts" aria-label="Contact channels">
  <p class="text-caption muted">contacts</p>
  <ul class="row">
    {/* Email icon: popover trigger if multiple, plain mailto link otherwise. */}
    {primaryEmail && (
      <li>
        <Tooltip label={hasMultipleEmails ? 'Email' : primaryEmail.label} side="top">
          {hasMultipleEmails ? (
            <button
              type="button"
              class="icon-link"
              popovertarget="email-popover"
              aria-label={`Email — ${emails.length} addresses`}
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width={iconStrokeWidth}
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d={iconPaths.email} />
              </svg>
            </button>
          ) : (
            <a
              class="icon-link"
              href={primaryEmail.url}
              aria-label={`${primaryEmail.label} — ${primaryEmail.handle}`}
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width={iconStrokeWidth}
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d={iconPaths.email} />
              </svg>
            </a>
          )}
        </Tooltip>
      </li>
    )}

    {nonEmails.map((c) => (
      <li>
        <Tooltip label={c.label} side="top">
          <a
            class="icon-link"
            href={c.url}
            aria-label={`${c.label} — ${c.handle}`}
            rel="me noopener"
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width={iconStrokeWidth}
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d={iconPaths[c.kind]} />
            </svg>
          </a>
        </Tooltip>
      </li>
    ))}
  </ul>

  {/* Bottom-right CTA. Wrapped in tooltip for label parity with icon row. */}
  <div class="cta-wrap">
    <Tooltip label="30-min meeting" side="top">
      <a class="book-cta" href="/book" data-astro-prefetch>
        <span>Book a call</span>
        <svg
          width="12"
          height="12"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M7 17L17 7M9 7h8v8" />
        </svg>
      </a>
    </Tooltip>
  </div>
</section>

{/* Email popover — top-layer overlay, native dismiss (click outside / ESC).
    Rendered outside the .contacts section to avoid being clipped by the
    sidebar's overflow rules. */}
{hasMultipleEmails && (
  <div id="email-popover" popover="auto" class="email-popover glass">
    <p class="text-caption muted email-popover-head">choose an address</p>
    <ul class="email-list">
      {emails.map((e) => (
        <li class="email-row">
          <span class="email-label text-small">{e.label}</span>
          <a class="email-handle text-mono-small" href={e.url}>{e.handle}</a>
        </li>
      ))}
    </ul>
  </div>
)}

<style>
  .muted {
    color: var(--text-muted);
  }
  .contacts {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .row {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    color: var(--text);
    background: transparent;
    padding: 0;
    cursor: pointer;
    transition:
      color var(--duration-normal) var(--ease-out-expo),
      border-color var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
  }
  .icon-link:hover,
  .icon-link:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .icon-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /*
   * Book a call CTA — quiet text + arrow-up-right, right-aligned in the
   * section. Hover lifts and tints with the accent, matching the icon-link
   * affordance so the cluster reads as one set.
   */
  .cta-wrap {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.25rem;
  }
  .book-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    color: var(--text);
    font-family: var(--font-sans);
    font-weight: 500;
    font-size: 12.5px;
    line-height: 1;
    letter-spacing: -0.005em;
    cursor: pointer;
    transition:
      color var(--duration-normal) var(--ease-out-expo),
      border-color var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
  }
  .book-cta:hover,
  .book-cta:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .book-cta:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .book-cta svg {
    transition: transform var(--duration-normal) var(--ease-out-expo);
  }
  .book-cta:hover svg,
  .book-cta:focus-visible svg {
    transform: translate(1px, -1px);
  }
</style>

<style is:global>
  /*
   * Email popover — top-layer overlay (HTML Popover API). Default browser
   * positioning is centered; we override to a comfortable mid-screen card.
   * Backdrop and ESC dismiss are native. Sized to fit three rows + header
   * without scroll.
   *
   * The popover element renders in the top layer outside any scoped style
   * boundary, so its rules live in :global. ::backdrop is the dimmed scrim
   * the browser draws behind a `popover="auto"` element when open.
   */
  .email-popover {
    /* Override UA defaults — popover elements are absolutely positioned;
       margin: auto + inset: 0 centers the card in the viewport. */
    margin: auto;
    padding: 1rem 1.1rem;
    border: 1px solid var(--border-strong);
    border-radius: 14px;
    min-width: min(320px, 90vw);
    max-width: 420px;
    color: var(--text);
    inset: 0;
  }
  .email-popover::backdrop {
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(2px);
  }
  .email-popover-head {
    color: var(--text-muted);
    margin: 0 0 0.6rem 0;
  }
  .email-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .email-row {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.55rem 0;
    border-top: 1px solid var(--border);
  }
  .email-row:first-child {
    border-top: none;
  }
  .email-label {
    color: var(--text);
  }
  .email-handle {
    color: var(--text-muted);
    text-align: right;
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
    transition: color var(--duration-normal) var(--ease-out-expo);
  }
  .email-handle:hover,
  .email-handle:focus-visible {
    color: var(--accent);
  }
</style>
