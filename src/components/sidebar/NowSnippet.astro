---
/**
 * Sidebar "now" snippet — single source of truth in `src/data/now.ts`.
 *
 * The availability dot is a one-glance signal:
 *   available → green
 *   limited → amber
 *   unavailable → red
 *
 * Tokens come from `tokens.css` (`--availability-*`) so the colors flip
 * correctly per theme.
 */
import { now } from '../../data/now';

const availabilityLabel: Record<typeof now.availability, string> = {
  available: 'available',
  limited: 'limited',
  unavailable: 'unavailable',
};

const updatedRelative = (() => {
  const updated = new Date(now.updatedAt);
  const days = Math.max(
    0,
    Math.floor((Date.now() - updated.getTime()) / 86_400_000),
  );
  if (days === 0) return 'today';
  if (days === 1) return 'yesterday';
  if (days < 30) return `${days} days ago`;
  if (days < 365) return `${Math.floor(days / 30)} months ago`;
  return `${Math.floor(days / 365)} years ago`;
})();
---

<section class="now" aria-label="What I'm doing now">
  <header class="head">
    <span class="text-caption muted">now</span>
    <span class={`availability avail-${now.availability}`}>
      <span class="dot" aria-hidden="true"></span>
      <span class="text-caption">{availabilityLabel[now.availability]}</span>
    </span>
  </header>

  <p class="status text-small">{now.status}</p>

  <p class="meta text-caption muted">
    <span>{now.location}</span>
    <span class="sep" aria-hidden="true">·</span>
    <span>updated {updatedRelative}</span>
  </p>
</section>

<style>
  .muted {
    color: var(--text-muted);
  }

  .now {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }
  .availability {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-transform: lowercase;
    letter-spacing: 0;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--text-muted);
    box-shadow: 0 0 0 2px transparent;
    transition: box-shadow var(--duration-normal) var(--ease-out-expo);
  }
  /* Halos derive from the same per-theme availability token via color-mix,
     so dot + halo always agree across light and dark themes. */
  .avail-available .dot {
    background: var(--availability-available);
    box-shadow:
      0 0 0 3px color-mix(in oklab, var(--availability-available) 22%, transparent);
  }
  .avail-limited .dot {
    background: var(--availability-limited);
    box-shadow:
      0 0 0 3px color-mix(in oklab, var(--availability-limited) 22%, transparent);
  }
  .avail-unavailable .dot {
    background: var(--availability-unavailable);
    box-shadow:
      0 0 0 3px color-mix(in oklab, var(--availability-unavailable) 22%, transparent);
  }
  .availability span:not(.dot) {
    color: var(--text-muted);
  }

  .status {
    margin: 0;
    color: var(--text);
    line-height: 1.45;
    /* 3 lines fits the sidebar at typical viewport heights without stealing
       room from the Spotify flex-fill below. Drops to 2 on short viewports. */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  @media (max-height: 800px) {
    .status {
      -webkit-line-clamp: 2;
      line-clamp: 2;
    }
  }

  .meta {
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: baseline;
  }
  .sep {
    opacity: 0.6;
  }
</style>
