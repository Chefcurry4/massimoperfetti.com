---
/**
 * Sidebar Spotify embed.
 *
 * Uses Spotify's official embed iframe — no API token, no backend.
 *
 * Privacy footprint: the iframe lives in the persistent sidebar, so it's
 * in-viewport on first paint. `loading="lazy"` would be a no-op here and
 * has been removed. Spotify will phone home immediately, which CLAUDE.md
 * §Open questions flags as undecided. Phase 8 (or sooner if asked) will
 * upgrade this to a click-to-load placeholder pattern.
 *
 * Height: the iframe flex-fills whatever space is left in the sidebar after
 * Identity, Now, and Contacts have taken theirs. Floor 200px so it's still
 * usable; cap 420px so it doesn't dominate on tall monitors. The HTML
 * `height` attribute is omitted because CSS controls layout — the iframe
 * height attribute would conflict with `height: 100%`.
 */
import { site } from '../../data/site';

const playlistTitle = "Massimo's playlist";
---

<section class="spotify" aria-label="Currently listening">
  <p class="text-caption muted">listening</p>

  <div class="frame">
    <iframe
      src={`${site.spotifyEmbedUrl}?utm_source=generator&theme=0`}
      title={playlistTitle}
      allow="autoplay; clipboard-write; encrypted-media; picture-in-picture"
    ></iframe>
  </div>
</section>

<style>
  .muted {
    color: var(--text-muted);
  }
  .spotify {
    /* Absorb remaining vertical space in the sidebar. Floor + ceiling keep
       the player usable on tall and short monitors. */
    flex: 1 1 auto;
    min-height: 200px;
    max-height: 420px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .frame {
    flex: 1 1 auto;
    min-height: 0;
    width: 100%;
    line-height: 0;
  }
  .frame iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: none;
    border-radius: 12px;
  }
</style>
