---
/**
 * Sidebar Spotify link.
 *
 * Was a full embed iframe; replaced by a logo-only outbound link to the
 * playlist on Spotify. Trade-offs of the new approach:
 *   + Zero third-party network on first paint (no Spotify scripts/cookies).
 *   + No iframe height tuning, no white space.
 *   + Editorial restraint — fits the academic-portfolio tone.
 *   - Visitor must click out to actually hear anything.
 *
 * The public playlist URL is derived from `site.spotifyEmbedUrl` so the
 * source of truth stays in one place: convert `/embed/playlist/{id}` →
 * `/playlist/{id}`.
 */
import { site } from '../../data/site';

const playlistUrl = site.spotifyEmbedUrl.replace('/embed/playlist/', '/playlist/');
---

<section class="spotify" aria-label="Currently listening">
  <p class="text-caption muted">listening</p>

  <a
    class="card-link"
    href={playlistUrl}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Open my playlist on Spotify (new tab)"
  >
    <svg
      class="logo"
      width="28"
      height="28"
      viewBox="0 0 168 168"
      aria-hidden="true"
    >
      {/* Official Spotify mark — circle with three sound-wave arcs.
          Filled with currentColor so it follows the link's text color
          (muted at rest, accent on hover). */}
      <path
        fill="currentColor"
        d="M83.996.277C37.747.277.253 37.77.253 84.019c0 46.251 37.494 83.741 83.743 83.741 46.254 0 83.744-37.49 83.744-83.741 0-46.246-37.49-83.738-83.745-83.738l.001-.004zm38.404 120.78a5.217 5.217 0 0 1-7.18 1.73c-19.662-12.01-44.414-14.73-73.564-8.07a5.222 5.222 0 0 1-6.249-3.93 5.213 5.213 0 0 1 3.926-6.25c31.9-7.291 59.263-4.15 81.337 9.34 2.46 1.51 3.24 4.72 1.73 7.18zm10.25-22.805c-1.89 3.075-5.91 4.045-8.98 2.155-22.51-13.839-56.823-17.846-83.448-9.764-3.453 1.043-7.1-.903-8.148-4.35a6.538 6.538 0 0 1 4.354-8.143c30.413-9.228 68.222-4.758 94.072 11.127 3.07 1.89 4.04 5.91 2.15 8.976v-.001zm.88-23.744c-26.99-16.031-71.52-17.505-97.289-9.684-4.138 1.255-8.514-1.081-9.768-5.219a7.835 7.835 0 0 1 5.221-9.771c29.581-8.98 78.756-7.245 109.83 11.202a7.823 7.823 0 0 1 2.74 10.733c-2.2 3.722-7.02 4.949-10.73 2.739z"
      />
    </svg>

    <span class="label text-ui">Open my playlist</span>

    <svg
      class="arrow"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M7 17L17 7M9 7h8v8" />
    </svg>
  </a>
</section>

<style>
  .muted {
    color: var(--text-muted);
  }
  .spotify {
    /* Sized to its content — no flex-grow. The remaining sidebar space
       cleanly pushes the footer down via the footer's `margin-top: auto`. */
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-strong);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition:
      color var(--duration-normal) var(--ease-out-expo),
      border-color var(--duration-normal) var(--ease-out-expo),
      transform var(--duration-normal) var(--ease-out-expo);
  }
  .card-link:hover,
  .card-link:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .logo {
    flex-shrink: 0;
    transition: transform var(--duration-normal) var(--ease-out-expo);
  }
  .label {
    flex: 1 1 auto;
    color: var(--text);
    transition: color var(--duration-normal) var(--ease-out-expo);
  }
  .card-link:hover .label,
  .card-link:focus-visible .label {
    color: var(--accent);
  }
  .arrow {
    flex-shrink: 0;
    transition: transform var(--duration-normal) var(--ease-out-expo);
  }
  .card-link:hover .arrow,
  .card-link:focus-visible .arrow {
    transform: translate(2px, -2px);
  }

  /* Reduced-motion: keep the color affordances, drop the position deltas.
     Global rules collapse transition durations but the destination
     transform still applies; explicitly resetting transform here matches
     the canonical pattern from RelatedProjects. */
  @media (prefers-reduced-motion: reduce) {
    .card-link:hover,
    .card-link:focus-visible {
      transform: none;
    }
    .card-link:hover .arrow,
    .card-link:focus-visible .arrow {
      transform: none;
    }
  }
</style>
