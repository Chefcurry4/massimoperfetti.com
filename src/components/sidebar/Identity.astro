---
/**
 * Sidebar identity block: gradient avatar + name + degree line.
 *
 * The avatar is a 36px circle filled with --gradient-cool (no photo, no
 * availability ring). Name sits in --text on top of it; the degree line
 * sits below in --text-muted to keep visual weight on the name.
 */
import { site } from '../../data/site';

const role = 'MSc Mechanical Engineering MIT | TUDelft';
---

<div class="identity">
  <div
    class="avatar"
    role="img"
    aria-label={`Portrait of ${site.name}`}
  ></div>
  <div class="text">
    <p class="name text-body">{site.name}</p>
    <p class="role text-caption muted">{role}</p>
  </div>
</div>

<style>
  .muted {
    color: var(--text-muted);
  }
  .identity {
    display: grid;
    grid-template-columns: 36px 1fr;
    align-items: center;
    gap: var(--space-3);
  }
  .avatar {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-pill);
    background-image: var(--gradient-cool);
    flex-shrink: 0;
  }
  .text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .name {
    margin: 0;
    color: var(--text);
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .role {
    margin: 0;
    /* role line is dense — let it wrap to 2 lines max in the narrow column */
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
