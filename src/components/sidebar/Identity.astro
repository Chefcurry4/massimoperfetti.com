---
/**
 * Sidebar identity block: gradient avatar, name, role.
 *
 * The avatar is a 36px circle filled with `--gradient-cool` (no photo).
 * The colored ring around it signals real-time availability via
 * `now.availability` — green/amber/red. This is the single most important
 * affordance on the collapsed rail: it preserves the "real-time context"
 * signal that NowSnippet otherwise hides until the sidebar expands.
 *
 * The ring is implemented as a stacked outline (inner gap via --surface,
 * outer ring via the availability token) so it reads as a halo, not a
 * border.
 */
import { site } from '../../data/site';
import { about } from '../../data/about';
import { now } from '../../data/now';

const ringColor = `var(--availability-${now.availability})`;
const availabilityLabel = `Currently ${now.availability}`;
---

<div class="identity">
  <div
    class="avatar"
    role="img"
    aria-label={`${site.name} — ${availabilityLabel}`}
    style={`--ring: ${ringColor};`}
  ></div>
  <div class="text">
    <p class="name text-body">{site.name}</p>
    <p class="role text-caption muted">{about.role}</p>
  </div>
</div>

<style>
  .muted {
    color: var(--text-muted);
  }
  .identity {
    display: grid;
    grid-template-columns: 36px 1fr;
    align-items: center;
    gap: var(--space-3);
  }
  .avatar {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-pill);
    background-image: var(--gradient-cool);
    flex-shrink: 0;
    /* Stacked rings: inner 2px in --surface (the breathing gap), outer 2px
       in the availability color. Reads as a soft halo around the avatar
       rather than a flat border. */
    box-shadow:
      0 0 0 2px var(--surface),
      0 0 0 4px var(--ring);
    transition: box-shadow var(--duration-normal) var(--ease-out-expo);
  }
  .text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .name {
    margin: 0;
    color: var(--text);
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .role {
    margin: 0;
    /* role line is dense — let it wrap to 2 lines max in the narrow column */
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
