---
/**
 * Sidebar identity block: avatar, name, role.
 *
 * The avatar uses the same /me.jpeg as AboutCell, sized down to a 48px circle.
 * Same gradient fallback (layered background-image) so missing photo shows
 * the gradient, not a broken icon.
 */
import { site } from '../../data/site';
import { about } from '../../data/about';
---

<div class="identity">
  <div
    class="avatar"
    role="img"
    aria-label={`Portrait of ${site.name}`}
  ></div>
  <div class="text">
    <p class="name text-body">{site.name}</p>
    <p class="role text-caption muted">{about.role}</p>
  </div>
</div>

<style>
  .muted {
    color: var(--text-muted);
  }
  .identity {
    display: grid;
    grid-template-columns: 48px 1fr;
    align-items: center;
    gap: 0.75rem;
  }
  .avatar {
    width: 48px;
    height: 48px;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    background-color: var(--surface);
    background-image:
      url('/me.jpeg'),
      linear-gradient(
        135deg,
        oklch(72% 0.12 264 / 0.85),
        oklch(38% 0.10 295 / 0.95)
      );
    background-size: cover, cover;
    background-position: center top, center;
    background-repeat: no-repeat, no-repeat;
    flex-shrink: 0;
  }
  .text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }
  .name {
    margin: 0;
    color: var(--text);
    font-size: 16px;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .role {
    margin: 0;
    /* role line is dense — let it wrap to 2 lines max in the narrow column */
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
