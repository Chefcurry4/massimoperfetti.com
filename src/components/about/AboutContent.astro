---
/**
 * Shared about content — centered editorial reading column.
 * Hosted by /about, which owns the page chrome (margin, sidebar offset,
 * footer, backdrop). Extracted as a component so the editorial body can
 * be reused if a second surface ever needs it.
 *
 * The `photos` array on `src/data/about.ts` is no longer rendered — kept
 * in the schema for future use.
 */
import { about } from '../../data/about';
---

<header class="head">
  <p class="text-caption muted">about</p>
  <h1 class="text-display headline">{about.headline}</h1>
</header>

<article class="essay">
  {about.body.map((paragraph) => (
    <p class="text-body">{paragraph}</p>
  ))}
</article>

<style>
  .muted {
    color: var(--text-muted);
  }

  .head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-align: center;
    max-width: 720px;
    /* Center the head block within the host's flex column */
    margin-inline: auto;
  }
  .headline {
    margin: 0;
    color: var(--text);
  }

  .essay {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    margin-top: var(--space-5);
    text-align: center;
    /* Reading column — keep it tight enough to scan, centered in the host. */
    max-width: 60ch;
    margin-inline: auto;
  }
  .essay p {
    margin: 0;
    color: var(--text);
  }
  /* Middle paragraphs muted for visual rhythm — first (intro) and last
     (closing) sit at full --text emphasis. */
  .essay p:not(:first-child):not(:last-child) {
    color: var(--text-muted);
  }
</style>
