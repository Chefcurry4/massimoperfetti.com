---
/**
 * AboutPopover — quick-read overlay triggered from the bento AboutCell.
 *
 * Native HTML Popover API (`popover="auto"`) — same convention as the
 * email-cluster popover in ContactsCluster.astro. ESC + click-outside
 * dismiss for free, no JS framework. The trigger lives in AboutCell
 * (a `<button popovertarget="about-popover">`).
 *
 * Body content is shared with /about via <AboutContent />, so the popup
 * and the deep-linkable page never drift.
 *
 * Mobile: behaves like a sheet (full-width, anchored to bottom via the
 * media query rule below).
 */
import AboutContent from './AboutContent.astro';
---

<div
  id="about-popover"
  popover="auto"
  class="about-popover glass"
  aria-label="About"
>
  <button
    type="button"
    class="close"
    popovertarget="about-popover"
    popovertargetaction="hide"
    aria-label="Close about"
  >
    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.75"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M6 6l12 12M18 6l-12 12" />
    </svg>
  </button>

  <div class="content">
    <AboutContent />

    <footer class="popover-footer">
      <a class="link text-caption" href="/about" data-astro-prefetch>
        → open as full page
      </a>
      <a class="link text-caption" href="/contact">
        → send a message
      </a>
    </footer>
  </div>
</div>

<style>
  .about-popover {
    /* Centered modal. Native [popover] sits in the top layer; we just need
       to size + position. Native ::backdrop is themed below. */
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(90vw, 720px);
    max-height: 85dvh;
    margin: 0;
    padding: 0;
    border-radius: var(--radius-lg);
    /* Base.astro keeps everything else; we just need overflow + scroll inside. */
    overflow: hidden;
    /* Override [popover]'s default white border + black background — the
       .glass class supplies the visual treatment. */
    border: 1px solid var(--border-strong);
    color: var(--text);
  }

  /* Native backdrop styled — modal scrim. */
  .about-popover::backdrop {
    background: var(--scrim-modal);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .close {
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    width: var(--control-h-md);
    height: var(--control-h-md);
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--text);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 1;
    transition:
      color var(--duration-fast) var(--ease-out-expo),
      border-color var(--duration-fast) var(--ease-out-expo);
  }
  .close:hover,
  .close:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
  }
  .close:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .content {
    /* Internal scroll — popup chrome stays fixed, body scrolls. */
    overflow-y: auto;
    overflow-x: hidden;
    max-height: 85dvh;
    padding:
      clamp(var(--space-5), 4vw, var(--space-7))
      clamp(var(--space-4), 4vw, var(--space-6))
      clamp(var(--space-5), 4vw, var(--space-6));
    display: flex;
    flex-direction: column;
  }

  .popover-footer {
    margin-top: var(--space-6);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .link:hover,
  .link:focus-visible {
    color: var(--accent);
  }
  .link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* Mobile — full-screen sheet. */
  @media (max-width: 720px) {
    .about-popover {
      top: 0;
      left: 0;
      transform: none;
      width: 100vw;
      height: 100dvh;
      max-height: 100dvh;
      border-radius: 0;
      border: none;
    }
    .content {
      max-height: 100dvh;
      padding-top: calc(var(--space-7) + env(safe-area-inset-top));
      padding-bottom: calc(var(--space-6) + env(safe-area-inset-bottom));
    }
  }
</style>
