---
/**
 * Base layout: HTML shell, head metadata, View Transitions wired,
 * theme bootstrap inlined to avoid FOUC, persistent sidebar mounted.
 *
 * The Sidebar uses `transition:persist` so it stays alive across all
 * Astro View Transitions navigations (Phase 4 morphs, Phase 5 detail
 * pages). Spotify keeps playing, theme toggle state survives.
 */
import { ClientRouter } from 'astro:transitions';
import { site } from '../data/site';
import Sidebar from '../components/sidebar/Sidebar.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** Alt text for the OG image — describes the social share preview content. */
  ogImageAlt?: string;
}

const {
  title = site.title,
  description = site.description,
  ogImage = site.defaultOgImage,
  ogImageAlt,
} = Astro.props;

const fullTitle = title === site.title ? title : `${title} — ${site.name}`;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogImageUrl = new URL(ogImage, site.url).toString();
// Avoid the "Name — Name" double-up on the home page when title === site.name.
const ogImageAltText =
  ogImageAlt ?? (title === site.title ? title : `${title} — ${site.name}`);

// Preload the AboutCell portrait on the home route only — it's the LCP
// candidate above the fold, so giving it `fetchpriority="high"` cuts ~600ms
// off the first paint vs. waiting for the bento grid to lay out first.
const isHome = Astro.url.pathname === '/';
---

<!doctype html>
<html lang={site.locale} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAltText} />
    <meta property="og:locale" content={site.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAltText} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${site.name} — writing`}
      href="/writing/rss.xml"
    />
    {
      isHome && (
        <link
          rel="preload"
          as="image"
          href="/me.webp"
          type="image/webp"
          fetchpriority="high"
        />
      )
    }

    {/* Theme bootstrap: synchronous, runs before first paint. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          var theme = stored === 'light' || stored === 'dark'
            ? stored
            : (prefersLight ? 'light' : 'dark');
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Sidebar />
    <slot />
  </body>
</html>
