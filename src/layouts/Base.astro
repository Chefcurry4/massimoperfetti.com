---
/**
 * Base layout: HTML shell, head metadata, View Transitions wired,
 * theme bootstrap inlined to avoid FOUC.
 *
 * Scope: shell only. Sidebar, bento grid, page-specific chrome are NOT here —
 * they belong to later phases (Phase 2 grid, Phase 3 sidebar).
 */
import { ClientRouter } from 'astro:transitions';
import { site } from '../data/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = site.title,
  description = site.description,
  ogImage = site.defaultOgImage,
} = Astro.props;

const fullTitle = title === site.title ? title : `${title} — ${site.name}`;
const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogImageUrl = new URL(ogImage, site.url).toString();
---

<!doctype html>
<html lang={site.locale} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={site.locale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Theme bootstrap: synchronous, runs before first paint. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          var theme = stored === 'light' || stored === 'dark'
            ? stored
            : (prefersLight ? 'light' : 'dark');
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <slot />
  </body>
</html>
