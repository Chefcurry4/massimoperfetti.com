---
/**
 * Writing detail — morph destination from the bento WritingCell.
 *
 * Title-led hero (no cover image — writing entries don't have one in the
 * schema), markdown body rendered via Astro's content-layer `render()`,
 * back link.
 *
 * View Transitions naming:
 *   poster-writing-{slug}        → wrapping <article>
 *   poster-writing-{slug}-title  → <h1>
 */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('writing', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'writing'>;
}

const { entry } = Astro.props;
const { title, summary, date, tags, readingTime } = entry.data;
const { Content } = await render(entry);

const dateLabel = date.toLocaleString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<Base title={title} description={summary}>
  <main class="page">
    <a href="/" class="back text-caption">← back</a>

    <article
      class="essay"
      transition:name={`poster-writing-${entry.id}`}
    >
      <header class="head">
        <p class="text-caption muted">writing</p>
        <h1
          class="title text-display"
          transition:name={`poster-writing-${entry.id}-title`}
        >{title}</h1>

        <p class="meta text-caption muted">
          <span>{dateLabel}</span>
          {readingTime && <span class="dot" aria-hidden="true">·</span>}
          {readingTime && <span>{readingTime} min read</span>}
        </p>

        {
          tags.length > 0 && (
            <ul class="tags" aria-label="tags">
              {tags.map((t) => (
                <li class="tag text-caption">{t}</li>
              ))}
            </ul>
          )
        }
      </header>

      <p class="lede text-body">{summary}</p>

      <div class="body">
        <Content />
      </div>
    </article>
  </main>
</Base>

<style>
  .page {
    min-height: calc(100dvh - 2 * var(--wall-inset));
    margin: var(--wall-inset);
    margin-left: calc(var(--wall-inset) + var(--sidebar-rail) + var(--sidebar-gap));
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 3vw, 2rem) 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 720px;
  }
  .muted {
    color: var(--text-muted);
  }
  .back {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
    align-self: flex-start;
  }
  .back:hover,
  .back:focus-visible {
    color: var(--text);
  }

  .essay {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .head {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .title {
    margin: 0;
    color: var(--text);
  }
  .meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: baseline;
  }
  .dot {
    opacity: 0.6;
  }
  .tags {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    padding: 0.18rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-muted);
  }

  .lede {
    margin: 0;
    color: var(--text);
    /* slightly larger / heavier than body to set the tone */
    font-size: 18px;
    line-height: 1.55;
  }

  .body {
    color: var(--text);
    line-height: 1.7;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 0.5rem;
  }
  .body :global(h2) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 1.5rem 0 0.25rem;
    color: var(--text);
  }
  .body :global(h3) {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 18px;
    line-height: 1.3;
    margin: 1rem 0 0.25rem;
    color: var(--text);
  }
  .body :global(p) {
    margin: 0;
  }
  .body :global(ol),
  .body :global(ul) {
    padding-left: 1.25rem;
    margin: 0;
  }
  .body :global(li) {
    margin: 0.25rem 0;
  }
  .body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    background: var(--surface);
    border: 1px solid var(--border);
  }
  .body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 1023.98px) {
    .page {
      margin: 0;
      padding: 16px 16px 88px;
    }
  }
</style>
