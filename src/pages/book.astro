---
/**
 * /book — Cal.com booking surface.
 *
 * Embeds the public Cal.com event-type page in an iframe. Massimo's Cal.com
 * account owns the Google Calendar OAuth so the site stays static (no
 * Netlify Functions, no token storage, no env vars).
 *
 * Theme is passed via `?theme=auto` so the embed inherits the visitor's
 * system theme. To switch to Cal.com's official embed.js for tighter color
 * sync, replace the iframe with the inline embed snippet from
 * https://cal.com/docs/embed/inline.
 */
import Base from '../layouts/Base.astro';
import { site } from '../data/site';

const embedSrc = `${site.bookingUrl}?theme=auto&hideEventTypeDetails=false`;

// Plain personal email for the fallback line — keep this in sync with
// src/data/contacts.ts (first email entry).
const fallbackEmail = 'massimoperfetti4@gmail.com';
---

<Base
  title="Book a call"
  description="Pick a 30-minute slot. Synced to Massimo's Google Calendar."
>
  <main class="page">
    <header class="head">
      <p class="text-caption muted">book</p>
      <h1 class="text-h1 headline">Book a call</h1>
      <p class="text-body muted intro">
        30 minutes. Pick a time that works.
      </p>
    </header>

    <div class="embed-wrap">
      <iframe
        src={embedSrc}
        title="Book a 30-min call with Massimo Perfetti"
        loading="lazy"
        referrerpolicy="strict-origin-when-cross-origin"
        allow="clipboard-write; payment"
      ></iframe>
    </div>

    <footer class="meta">
      <span class="text-caption muted">
        Or just email — <a class="email" href={`mailto:${fallbackEmail}`}>{fallbackEmail}</a>
      </span>
      <a href="/" class="back-link text-caption">← back</a>
    </footer>
  </main>
</Base>

<style>
  /* Sidebar-aware page container: anchored to the collapsed rail width on
     desktop so the expanded sidebar floats over without reflow. Sized to
     the visible viewport (100dvh - 2 * inset) so the iframe below can
     flex-fill instead of needing its own scrollbar. */
  /* /book is the one detail-style page that needs `height` (not min-height)
     so the iframe can flex-fill the remaining space. So it doesn't use the
     global `.detail-page` class — the constraint is different. Back link
     uses the global `.back-link` class via the markup. */
  .page {
    height: calc(100dvh - 2 * var(--wall-inset));
    margin: var(--wall-inset);
    margin-left: calc(var(--wall-inset) + var(--sidebar-rail) + var(--sidebar-gap));
    padding:
      clamp(var(--space-5), 3vw, var(--space-6))
      clamp(var(--space-4), 3vw, var(--space-6))
      clamp(var(--space-4), 2vw, var(--space-5));
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 920px;
    /* min-height: 0 cascades into children so the iframe can shrink below
       its intrinsic size when needed. */
    min-height: 0;
  }
  .muted {
    color: var(--text-muted);
  }
  .head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .headline {
    margin: 0;
    color: var(--text);
  }
  .intro {
    margin: 0;
  }

  .embed-wrap {
    /* Absorb the remaining vertical space after header + meta footer.
       `min-height: 0` is required for flex-shrink to work below intrinsic
       size; `flex: 1 1 auto` lets the iframe fill what's available without
       a hardcoded clamp that overflows on shorter laptop viewports. */
    flex: 1 1 auto;
    min-height: 0;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--surface);
    box-shadow: 0 8px 32px var(--glass-shadow);
  }
  .embed-wrap iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
  }
  .email {
    color: var(--text);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .email:hover {
    color: var(--accent);
  }

  @media (max-width: 1023.98px) {
    .page {
      /* Mobile: full-bleed, content-sized height (the bento page already
         scrolls vertically as a long stack, so /book can flow the same way).
         Drawer handle clearance via padding-bottom. */
      height: auto;
      min-height: calc(100dvh - calc(var(--space-7) + var(--space-5)));
      margin: 0;
      padding: var(--space-4) var(--space-4) calc(var(--space-7) + var(--space-5));
    }
    .embed-wrap {
      /* Give the embed a real height target on mobile (no flex-fill — the
         page is content-sized). Cap at 80dvh so the user can still see
         the back link below. */
      flex: 0 0 auto;
      min-height: 80dvh;
    }
  }
</style>
