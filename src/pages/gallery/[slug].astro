---
/**
 * Gallery detail — morph destination from the bento GalleryCell.
 *
 * Phase 4: minimal landing page so the morph has somewhere to go. Phase 7
 * upgrades this to a proper gallery detail / lightbox treatment.
 *
 * Hero is the gradient frame (matching the bento source via shared hash),
 * meta below: title, caption, location, exif.
 *
 * View Transitions naming:
 *   poster-gallery-{slug}        → wrapping <article>
 *   poster-gallery-{slug}-image  → cover frame
 */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { hashHue } from '../../lib/cover-color';
import Lightbox from '../../components/gallery/Lightbox.astro';

export async function getStaticPaths() {
  const entries = await getCollection('gallery');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'gallery'>;
}

const { entry } = Astro.props;
const { title, image, caption, location, exif, date } = entry.data;
const { Content } = await render(entry);

// Same 60° hue spread as GalleryCell so source + destination gradients agree.
// The gradient sits behind the <img>; if the file 404s, the gradient stays
// visible (no broken-icon, no flag-flipping — same pattern as AboutCell).
const hue = hashHue(title);
const hueAlt = (hue + 60) % 360;
const fallbackStyle = `--hue: ${hue}; --hue-alt: ${hueAlt};`;

const dateLabel = date.toLocaleString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<Base title={title} description={caption ?? title}>
  <main class="detail-page page">
    <a href="/" class="back-link text-caption">← back</a>

    <article
      class="photograph"
      transition:name={`poster-gallery-${entry.id}`}
    >
      <button
        type="button"
        class="frame-button"
        popovertarget="photo-lightbox"
        aria-label={`Open ${title} at full size`}
      >
        <div
          class="frame"
          style={fallbackStyle}
          transition:name={`poster-gallery-${entry.id}-image`}
        >
          <img
            src={image}
            alt={caption ?? title}
            width="1600"
            height="1067"
            loading="eager"
            decoding="async"
          />
        </div>
      </button>

      <div class="meta">
        <p class="text-caption muted">photograph</p>
        <h1 class="title text-h1">{title}</h1>
        {caption && <p class="caption text-body">{caption}</p>}

        <dl class="exif" aria-label="photo metadata">
          <div class="row">
            <dt class="text-caption muted">date</dt>
            <dd class="text-small">{dateLabel}</dd>
          </div>
          {
            location && (
              <div class="row">
                <dt class="text-caption muted">location</dt>
                <dd class="text-small">{location}</dd>
              </div>
            )
          }
          {
            exif?.camera && (
              <div class="row">
                <dt class="text-caption muted">camera</dt>
                <dd class="text-small">{exif.camera}</dd>
              </div>
            )
          }
          {
            (exif?.lens || exif?.fStop) && (
              <div class="row">
                <dt class="text-caption muted">lens</dt>
                <dd class="text-small">
                  {[exif?.lens, exif?.fStop].filter(Boolean).join(' · ')}
                </dd>
              </div>
            )
          }
        </dl>
      </div>

      {
        Content && (
          <div class="prose">
            <Content />
          </div>
        )
      }
    </article>
  </main>

  <Lightbox src={image} alt={caption ?? title} caption={caption} />
</Base>

<style>
  /* Page chrome from `.detail-page`; back link from `.back-link`; markdown
     body from `.prose`. Local rules cover only the page-specific layout. */
  .page {
    max-width: 1080px;
  }
  .muted {
    color: var(--text-muted);
  }

  .photograph {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* Click-to-zoom — the photo wraps in a transparent <button> that triggers
     the Lightbox popover. Reset native button chrome so the only visual is
     the inner .frame. */
  .frame-button {
    display: block;
    width: 100%;
    margin: 0;
    padding: 0;
    background: transparent;
    border: none;
    cursor: zoom-in;
    border-radius: var(--radius-md);
  }
  .frame-button:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .frame {
    border-radius: var(--radius-md);
    border: 1px solid var(--border);
    overflow: hidden;
    aspect-ratio: 3 / 2;
    max-height: 75dvh;
    /* Layered: gradient sits below the image so a missing /public/gallery/*
       file shows the gradient, not a broken-icon. Same pattern as AboutCell. */
    background:
      linear-gradient(
        135deg,
        oklch(72% 0.16 var(--hue) / 0.9),
        oklch(40% 0.12 var(--hue-alt) / 0.95)
      );
    transition: transform var(--duration-normal) var(--ease-out-expo);
  }
  .frame-button:hover .frame,
  .frame-button:focus-visible .frame {
    transform: scale(1.005);
  }
  @media (prefers-reduced-motion: reduce) {
    .frame-button:hover .frame,
    .frame-button:focus-visible .frame {
      transform: none;
    }
  }
  .frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 720px;
  }
  .title {
    margin: 0;
    color: var(--text);
  }
  .caption {
    margin: 0;
    color: var(--text);
  }

  .exif {
    margin: var(--space-2) 0 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  .exif .row {
    display: grid;
    grid-template-columns: 96px 1fr;
    gap: var(--space-3);
    padding: var(--space-1) 0;
    border-top: 1px solid var(--border);
    align-items: baseline;
  }
  .exif .row:first-child {
    border-top: 1px solid var(--border-strong);
  }
  .exif dt {
    margin: 0;
  }
  .exif dd {
    margin: 0;
    color: var(--text);
  }

</style>
