---
/**
 * /gallery/[slug] — fullscreen photo on a liquid-glass backdrop.
 *
 * The page IS the zoomed view. Sidebar stays visible; the rest of the
 * viewport is a soft cool-gradient bg with the photo centered. Two anchors
 * at the top corners: ← back to home, and "all photos →" to the /gallery feed.
 *
 * Morph source can be the bento GalleryCell (from /) or a feed thumbnail
 * (from /gallery) — only one is on the source page per navigation, so the
 * shared `poster-gallery-{slug}` / `-image` names never collide.
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { hashHue } from '../../lib/cover-color';

export async function getStaticPaths() {
  const entries = await getCollection('gallery');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'gallery'>;
}

const { entry } = Astro.props;
const { title, image, caption } = entry.data;

// 60° spread mirrors GalleryCell so source + destination gradients agree.
const hue = hashHue(title);
const hueAlt = (hue + 60) % 360;
const fallbackStyle = `--hue: ${hue}; --hue-alt: ${hueAlt};`;
---

<Base
  title={title}
  description={caption ?? title}
  ogImage={`/og/gallery/${entry.id}.png`}
  ogImageAlt={caption ?? title}
>
  <main id="main" class="photo-view" transition:name={`poster-gallery-${entry.id}`}>
    <a href="/" class="corner back text-caption" aria-label="Back to wall">
      ← back
    </a>

    <a
      href="/gallery"
      class="corner show-all text-caption"
      data-astro-prefetch
    >
      all photos →
    </a>

    <figure
      class="frame"
      style={fallbackStyle}
      transition:name={`poster-gallery-${entry.id}-image`}
    >
      <img
        src={image}
        alt={caption ?? title}
        width="1600"
        height="1067"
        loading="eager"
        decoding="async"
      />
      {caption && <figcaption class="caption text-caption">{caption}</figcaption>}
    </figure>
  </main>
</Base>

<style>
  .photo-view {
    /* Anchored to the collapsed sidebar rail so the wall and this view share
       a left edge — sidebar floats over via z-index when expanded, no reflow. */
    min-height: 100dvh;
    margin-left: calc(var(--sidebar-rail) + var(--sidebar-gap));
    width: calc(100% - var(--sidebar-rail) - var(--sidebar-gap));
    /* Liquid-glass backdrop: soft cool gradient under a vignette. The image
       provides the focal contrast; the bg is intentionally muted. */
    background:
      radial-gradient(circle at 50% 50%, transparent 0%, var(--scrim-soft) 100%),
      var(--gradient-cool);
    display: grid;
    place-items: center;
    padding:
      clamp(var(--space-6), 4vw, var(--space-7))
      clamp(var(--space-4), 3vw, var(--space-6));
    position: relative;
    overflow: hidden;
  }
  @media (max-width: 1023.98px) {
    .photo-view {
      margin-left: 0;
      width: 100%;
      /* clear the bottom drawer (~64px) plus breathing room */
      padding-bottom: calc(var(--space-7) + var(--space-5));
    }
  }

  .corner {
    position: absolute;
    top: max(var(--space-4), env(safe-area-inset-top));
    color: var(--on-cover);
    text-decoration: none;
    z-index: 1;
    /* Slight contrast shadow against any photo color that bleeds near the
       corners — same trick the lightbox caption used. */
    text-shadow: 0 1px 2px var(--scrim-soft);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .corner:hover,
  .corner:focus-visible {
    color: var(--accent);
  }
  .corner:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }
  .back {
    left: max(var(--space-5), env(safe-area-inset-left));
  }
  .show-all {
    right: max(var(--space-5), env(safe-area-inset-right));
  }

  .frame {
    margin: 0;
    max-width: min(95vw, 1280px);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
    /* Gradient fallback applies if <img> 404s — matches the bento source. */
    --gradient: linear-gradient(
      135deg,
      oklch(72% 0.16 var(--hue) / 0.9),
      oklch(40% 0.12 var(--hue-alt) / 0.95)
    );
  }
  .frame img {
    max-width: 100%;
    /* Allow vertical fill but reserve room for back/show-all + caption. */
    max-height: calc(100dvh - var(--space-8) * 2);
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: var(--radius-md);
    background: var(--gradient);
    box-shadow:
      0 1px 0 0 var(--glass-highlight) inset,
      0 24px 64px var(--scrim-medium);
  }
  .caption {
    color: var(--on-cover);
    text-align: center;
    text-shadow: 0 1px 2px var(--scrim-soft);
    max-width: 64ch;
  }
</style>
