---
/**
 * /contact — message form (Netlify Forms).
 *
 * Declarative: `data-netlify="true"` on the <form> tells Netlify's build
 * detector to register the form. Submissions appear in the Netlify dashboard.
 * No backend, no functions, no env vars (per CLAUDE.md §Stack — locked).
 *
 * Honeypot: `netlify-honeypot="bot-field"` + a visually-hidden input named
 * "bot-field" — bots fill it in, real users don't.
 *
 * On success, Netlify redirects to /thanks.
 *
 * Local dev caveat: Astro's dev server doesn't accept the form POST — that's
 * handled by Netlify's build pipeline. Once deployed, the form works.
 */
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
---

<Base
  title="Contact"
  description={`Send a message to ${site.name}.`}
>
  <main class="detail-page page">
    <a href="/" class="back-link text-caption">← back</a>

    <header class="head">
      <p class="text-caption muted">contact</p>
      <h1 class="text-h1 headline">Send a message</h1>
      <p class="lede text-body muted">
        For longer threads or attachments. For a 30-min call, the
        <a href="/book" class="inline-link" data-astro-prefetch>/book</a> form is faster.
      </p>
    </header>

    <form
      class="form"
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/thanks"
    >
      {/* Required by Netlify Forms — pairs the submission with the form's name. */}
      <input type="hidden" name="form-name" value="contact" />

      {/* Honeypot — visually hidden, accessible-tree hidden. Bots fill it,
          humans never see it. Netlify drops any submission that has it set. */}
      <p class="hp" hidden aria-hidden="true">
        <label>
          Don't fill this if you're a human:
          <input name="bot-field" tabindex="-1" autocomplete="off" />
        </label>
      </p>

      <div class="field">
        <label for="contact-name" class="text-caption muted">name</label>
        <input
          id="contact-name"
          name="name"
          type="text"
          required
          autocomplete="name"
        />
      </div>

      <div class="field">
        <label for="contact-email" class="text-caption muted">email</label>
        <input
          id="contact-email"
          name="email"
          type="email"
          required
          autocomplete="email"
        />
      </div>

      <div class="field">
        <label for="contact-subject" class="text-caption muted">subject</label>
        <input
          id="contact-subject"
          name="subject"
          type="text"
        />
      </div>

      <div class="field">
        <label for="contact-message" class="text-caption muted">message</label>
        <textarea
          id="contact-message"
          name="message"
          rows="6"
          required
        ></textarea>
      </div>

      <button type="submit" class="submit text-ui">
        Send →
      </button>
    </form>
  </main>
</Base>

<style>
  /* Page chrome from `.detail-page`. Form column is narrower than max so
     the form reads as a focused interaction, not a wall. */
  .page {
    max-width: 640px;
  }
  .muted {
    color: var(--text-muted);
  }

  .head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .headline {
    margin: 0;
    color: var(--text);
  }
  .lede {
    margin: 0;
  }
  .inline-link {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .inline-link:hover,
  .inline-link:focus-visible {
    color: var(--accent);
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-top: var(--space-4);
  }
  .hp {
    /* Honeypot — invisible to humans. `hidden` attribute alone would also
       hide from screen readers, which is what we want here. */
    display: none;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .field input,
  .field textarea {
    /* font-size 16px is deliberate: iOS Safari auto-zooms on focus when an
       input's font-size is < 16px. Coincidentally matches .text-body — but
       the rationale is mobile-correctness, not the type scale. */
    font: inherit;
    font-size: 16px;
    line-height: 1.5;
    color: var(--text);
    background: var(--surface);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-md);
    padding: var(--space-3);
    width: 100%;
    transition:
      border-color var(--duration-fast) var(--ease-out-expo),
      box-shadow var(--duration-fast) var(--ease-out-expo);
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent) 20%, transparent);
  }
  .field textarea {
    resize: vertical;
    min-height: 144px;
    font-family: var(--font-sans);
  }

  .submit {
    align-self: flex-start;
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-pill);
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    transition:
      color var(--duration-fast) var(--ease-out-expo),
      border-color var(--duration-fast) var(--ease-out-expo),
      transform var(--duration-fast) var(--ease-out-expo);
  }
  .submit:hover,
  .submit:focus-visible {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .submit:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  @media (prefers-reduced-motion: reduce) {
    .submit:hover,
    .submit:focus-visible {
      transform: none;
    }
  }
</style>
