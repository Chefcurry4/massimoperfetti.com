---
/**
 * /about — standalone, deep-linkable page rendering the editorial about content.
 *
 * Page-only chrome: a dynamic grainy gradient backdrop (two soft radials
 * drifting across the viewport, plus an SVG fractal-noise overlay for film
 * grain). Both the drift and the noise honor `prefers-reduced-motion`.
 *
 * Body markup lives in `<AboutContent />`; this file owns only the page
 * chrome (sidebar-aware margin, padding, footer, backdrop).
 */
import Base from '../layouts/Base.astro';
import AboutContent from '../components/about/AboutContent.astro';
import { site } from '../data/site';
---

<Base
  title="About"
  ogImage="/og/about.png"
  ogImageAlt="About Massimo Perfetti"
>
  <main id="main" class="page">
    <AboutContent />

    <footer class="meta">
      <span class="text-caption">{site.name}</span>
      <a href="/" class="back-link text-caption">← back</a>
    </footer>
  </main>
</Base>

<style>
  /* Sidebar-aware page chrome. Centered text + max-width comes from
     AboutContent; this rule only positions the column relative to the
     viewport and provides the grainy backdrop. */
  .page {
    position: relative;
    margin-left: calc(var(--wall-inset) + var(--sidebar-rail) + var(--sidebar-gap));
    margin-right: var(--wall-inset);
    padding:
      clamp(var(--space-7), 10vh, var(--space-8))
      clamp(var(--space-4), 5vw, var(--space-6))
      var(--space-7);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    min-height: calc(100dvh - 2 * var(--wall-inset));
  }

  /*
   * Grainy gradient backdrop — two fixed-position layers behind everything.
   * ::before is the colored gradient (drifts slowly via animated
   * background-position); ::after is the SVG fractal-noise overlay.
   * Both are pointer-events: none and z-index -1 so they sit cleanly behind
   * the reading column without intercepting clicks. Sidebar's glass surface
   * lets the gradient show through subtly — that's intentional.
   */
  .page::before,
  .page::after {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
  }
  .page::before {
    background:
      radial-gradient(
        ellipse 60% 50% at 30% 25%,
        oklch(72% 0.12 264 / 0.38),
        transparent 70%
      ),
      radial-gradient(
        ellipse 55% 60% at 70% 75%,
        oklch(60% 0.18 295 / 0.32),
        transparent 70%
      ),
      var(--bg);
    background-size: 200% 200%, 200% 200%, auto;
    background-position: 0% 0%, 100% 100%, 0 0;
    animation: page-drift 32s ease-in-out infinite alternate;
  }
  .page::after {
    /* SVG fractal noise — film-grain texture so the gradient doesn't read
       as a flat color blob. Overlay blend keeps the grain subtle on light
       areas, visible on dark. */
    background-image: url("data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='200' height='200'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='2' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.5'/%3E%3C/svg%3E");
    opacity: 0.45;
    mix-blend-mode: overlay;
  }

  @keyframes page-drift {
    0% {
      background-position: 0% 0%, 100% 100%, 0 0;
    }
    100% {
      background-position: 100% 100%, 0% 0%, 0 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .page::before {
      animation: none;
    }
  }

  .meta {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-muted);
    width: 100%;
    max-width: 720px;
    margin-inline: auto;
  }

  @media (max-width: 720px) {
    .page {
      margin-left: 0;
      margin-right: 0;
      padding:
        clamp(var(--space-6), 8vw, var(--space-7))
        clamp(var(--space-4), 5vw, var(--space-5))
        calc(var(--space-7) + var(--space-5));
    }
  }
</style>
