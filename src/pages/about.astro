---
/**
 * /about — standalone page.
 *
 * Phase 2: simple linear page so deep-links work and there's somewhere
 * to send "back" navigation from. Phase 7 rebuilds this as a popup that
 * shares a transition with the bento About cell.
 */
import Base from '../layouts/Base.astro';
import { about } from '../data/about';
import { site } from '../data/site';
---

<Base title="About">
  <main class="page">
    <p class="text-caption muted">about</p>
    <h1 class="text-h1 headline">{about.headline}</h1>

    <div class="body">
      {about.body.map((paragraph) => <p class="text-body muted">{paragraph}</p>)}
    </div>

    <footer class="meta">
      <span class="text-caption">{site.name}</span>
      <a href="/" class="back text-caption">← back</a>
    </footer>
  </main>
</Base>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: clamp(2.5rem, 6vw, 5rem) clamp(1.25rem, 4vw, 2.5rem) 5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .muted {
    color: var(--text-muted);
  }
  .headline {
    margin: 0;
    color: var(--text);
  }
  .body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .meta {
    margin-top: 2.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-muted);
  }
  .back {
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .back:hover {
    color: var(--text);
  }
</style>
