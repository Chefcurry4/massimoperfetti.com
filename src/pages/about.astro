---
/**
 * /about — standalone page.
 *
 * Editorial reading column with three small photos interleaved between
 * body paragraphs. Photos alternate sides on desktop (right / left / right)
 * and stack inline on mobile. Each photo has a graceful CSS fallback
 * (gradient + caption) so a missing file doesn't show a broken-image icon —
 * mirrors the AboutCell portrait pattern.
 *
 * Phase 7 will rebuild this as a popup that shares a transition with the
 * bento About cell. For now it's a regular page so the read-more link works.
 */
import Base from '../layouts/Base.astro';
import { about } from '../data/about';
import { site } from '../data/site';

const [photoMountain, photoOrcas, photoCurry] = about.photos;
---

<Base title="About">
  <main class="page">
    <header class="head">
      <p class="text-caption muted">about</p>
      <h1 class="text-display headline">{about.headline}</h1>
    </header>

    <article class="essay">
      {/* Paragraph 1 — intro. */}
      <p class="text-body">{about.body[0]}</p>

      {/* Paragraph 2 — academic / research. Mountain photo to the right. */}
      <div class="row row-right">
        <p class="text-body muted">{about.body[1]}</p>
        {photoMountain && (
          <figure class={`photo ${photoMountain.aspect}`}>
            <img
              src={photoMountain.src}
              alt={photoMountain.alt}
              loading="lazy"
              decoding="async"
            />
            <figcaption class="text-mono-small">{photoMountain.caption}</figcaption>
          </figure>
        )}
      </div>

      {/* Paragraph 3 — Dual Energy. Orcas photo to the left. */}
      <div class="row row-left">
        <p class="text-body muted">{about.body[2]}</p>
        {photoOrcas && (
          <figure class={`photo ${photoOrcas.aspect}`}>
            <img
              src={photoOrcas.src}
              alt={photoOrcas.alt}
              loading="lazy"
              decoding="async"
            />
            <figcaption class="text-mono-small">{photoOrcas.caption}</figcaption>
          </figure>
        )}
      </div>

      {/* Paragraph 4 — interests. Basketball photo to the right (portrait). */}
      <div class="row row-right">
        <p class="text-body muted">{about.body[3]}</p>
        {photoCurry && (
          <figure class={`photo ${photoCurry.aspect}`}>
            <img
              src={photoCurry.src}
              alt={photoCurry.alt}
              loading="lazy"
              decoding="async"
            />
            <figcaption class="text-mono-small">{photoCurry.caption}</figcaption>
          </figure>
        )}
      </div>

      {/* Paragraph 5 — closing. */}
      <p class="text-body muted closing">{about.body[4]}</p>
    </article>

    <footer class="meta">
      <span class="text-caption">{site.name}</span>
      <a href="/" class="back-link text-caption">← back</a>
    </footer>
  </main>
</Base>

<style>
  /* Sidebar-aware page container. /about's vertical rhythm differs from the
     other detail pages (longer-form essay, deeper top padding) so it keeps a
     custom .page rule rather than using `.detail-page`. Back link uses the
     global `.back-link` class via markup. */
  .page {
    margin-left: calc(var(--wall-inset) + var(--sidebar-rail) + var(--sidebar-gap));
    margin-right: var(--wall-inset);
    padding:
      clamp(var(--space-6), 6vw, var(--space-8))
      clamp(var(--space-4), 3vw, var(--space-6))
      var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 880px;
  }
  .muted {
    color: var(--text-muted);
  }

  .head {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .headline {
    margin: 0;
    color: var(--text);
  }

  .essay {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  .essay p {
    margin: 0;
    max-width: 56ch; /* readable measure for body text */
  }
  .closing {
    color: var(--text);
  }

  /* Photo + paragraph rows.
     Two-column grid: text on one side, photo on the other. The .row-left /
     .row-right modifier swaps the photo position and which side the text
     occupies. Gap is generous so the photo feels like marginalia, not an
     inline figure. */
  .row {
    display: grid;
    align-items: center;
    gap: clamp(var(--space-4), 3vw, var(--space-6));
  }
  .row-right {
    grid-template-columns: minmax(0, 1fr) minmax(0, 220px);
  }
  .row-right .photo {
    justify-self: end;
  }
  .row-left {
    grid-template-columns: minmax(0, 220px) minmax(0, 1fr);
  }
  .row-left .photo {
    grid-column: 1;
    grid-row: 1;
    justify-self: start;
  }
  .row-left p {
    grid-column: 2;
    grid-row: 1;
  }

  /* Photo treatment — small, framed, with a thin caption underneath.
     Editorial print feel without being kitsch (no rotation, no filter). */
  .photo {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    width: 100%;
  }
  .photo img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    /* Layered fallback: if the image 404s, the gradient below stays visible
       so the page never shows a broken-image icon. Mirrors AboutCell — the
       soft variant of --gradient-cool reads as a backdrop, not a portrait. */
    background-color: var(--surface);
    background-image: var(--gradient-cool-soft);
    background-size: cover;
    box-shadow: 0 8px 24px var(--glass-shadow);
  }
  .photo.landscape img {
    aspect-ratio: 4 / 3;
  }
  .photo.portrait img {
    aspect-ratio: 3 / 4;
  }
  .photo figcaption {
    color: var(--text-muted);
    text-align: right;
  }
  .row-left .photo figcaption {
    text-align: left;
  }

  .meta {
    margin-top: var(--space-5);
    padding-top: var(--space-4);
    border-top: 1px solid var(--border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    color: var(--text-muted);
  }

  /* Mobile — collapse to single column. Photos stack inline below their
     paragraph (the row order in DOM puts text first for row-right, which
     reads naturally; row-left also reads paragraph-then-photo on mobile
     since the explicit grid-column rules are reset). */
  @media (max-width: 720px) {
    .page {
      margin-left: 0;
      margin-right: 0;
      padding:
        clamp(var(--space-6), 8vw, var(--space-7))
        clamp(var(--space-4), 5vw, var(--space-5))
        calc(var(--space-7) + var(--space-5));
    }
    .row,
    .row-right,
    .row-left {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .row-left .photo,
    .row-left p {
      grid-column: 1;
      grid-row: auto;
    }
    .photo {
      max-width: 320px;
    }
    .row-left .photo {
      align-self: start;
    }
    .row-right .photo {
      align-self: end;
    }
    .photo figcaption,
    .row-left .photo figcaption {
      text-align: left;
    }
  }
</style>
