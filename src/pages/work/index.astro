---
/**
 * /work — list of all non-draft work entries.
 *
 * Ordering: featured first, then by `period.start` desc. Each row links to
 * /work/{id}. Mirrors /projects/index.astro shape — minimal list view, the
 * detail page is where the editorial weight lives.
 */
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const entries = (await getCollection('work', ({ data }) => !data.draft)).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.period.start.getTime() - a.data.period.start.getTime();
});

function fmt(d: Date): string {
  return d.toLocaleString('en-US', { month: 'short', year: 'numeric' });
}
---

<Base title="Work" description="All work and roles.">
  <main id="main" class="detail-page page">
    <a href="/" class="back-link text-caption">← back</a>

    <header class="head">
      <p class="text-caption muted">work</p>
      <h1 class="text-h1 headline">All work</h1>
      <p class="lede text-body muted">
        {entries.length} in total. Click any row to read more.
      </p>
    </header>

    <ul class="list" aria-label="all work">
      {
        entries.map((entry) => {
          const periodLabel = `${fmt(entry.data.period.start)} — ${
            entry.data.period.end ? fmt(entry.data.period.end) : 'Present'
          }`;
          return (
            <li>
              <a class="row" href={`/work/${entry.id}`}>
                <div class="row-main">
                  <h2 class="text-h3 row-title">{entry.data.title}</h2>
                  <p class="text-small muted row-summary">
                    <span class="row-org">{entry.data.org}</span>
                    <span aria-hidden="true"> — </span>
                    {entry.data.summary}
                  </p>
                </div>
                <div class="row-meta">
                  <span class="row-period text-mono-small muted">{periodLabel}</span>
                  {entry.data.location && (
                    <span class="row-loc text-caption muted">{entry.data.location}</span>
                  )}
                </div>
              </a>
            </li>
          );
        })
      }
    </ul>
  </main>
</Base>

<style>
  .page {
    max-width: 920px;
  }
  .muted {
    color: var(--text-muted);
  }

  .head {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .headline {
    margin: 0;
    color: var(--text);
  }
  .lede {
    margin: 0;
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: var(--space-5);
    align-items: baseline;
    padding: var(--space-4) 0;
    border-top: 1px solid var(--border);
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .list li:last-child .row {
    border-bottom: 1px solid var(--border);
  }
  .row:hover .row-title,
  .row:focus-visible .row-title {
    color: var(--accent);
  }
  .row:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }
  .row-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .row-title {
    margin: 0;
    color: var(--text);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .row-summary {
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .row-org {
    color: var(--text);
  }
  .row-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: var(--space-1);
    white-space: nowrap;
  }

  @media (max-width: 600px) {
    .row {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
    .row-meta {
      align-items: flex-start;
      flex-direction: row;
      gap: var(--space-2);
    }
  }
</style>
