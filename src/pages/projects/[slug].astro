---
/**
 * Project detail page — the morph destination from the bento ProjectsCell.
 *
 * Hero is a full-bleed two-column split (chosen over a banner-then-text
 * layout — see plan §Resolved):
 *   left  — cover gradient (same coverHueVars(title) as the bento source so
 *           the morph is continuous) plus the title's first letter as the
 *           graphic centerpiece, just like the card.
 *   right — eyebrow + status pill + title (text-display) + summary + tags
 *           + links.
 *
 * Body is `<Content />` from Astro's content-layer `render()`, rendering
 * the markdown body with the body type scale.
 *
 * Mobile (<768px): hero stacks vertically, cover capped at 40dvh.
 *
 * View Transitions naming (CLAUDE.md §View Transitions convention):
 *   poster-projects-{slug}        → wrapping <article>
 *   poster-projects-{slug}-image  → cover gradient
 *   poster-projects-{slug}-title  → <h1>
 */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { coverHueVars } from '../../lib/cover-color';
import ReadingProgress from '../../components/detail/ReadingProgress.astro';
import RelatedProjects from '../../components/detail/RelatedProjects.astro';
import NextPrev from '../../components/detail/NextPrev.astro';

export async function getStaticPaths() {
  const entries = await getCollection('projects', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { title, summary, status, tags, links, date } = entry.data;
const { Content } = await render(entry);

const initial = title.trim().charAt(0).toUpperCase() || '·';
const coverStyle = coverHueVars(title);

const statusLabel: Record<typeof status, string> = {
  live: 'live',
  archived: 'archived',
  'in-progress': 'in progress',
};

const dateLabel = date.toLocaleString('en-US', {
  month: 'long',
  year: 'numeric',
});
---

<Base title={title} description={summary}>
  <ReadingProgress />
  <main class="detail-page page">
    <a href="/" class="back-link text-caption">← back</a>

    <article
      class="project"
      transition:name={`poster-projects-${entry.id}`}
    >
      <div class="hero">
        <div
          class="cover"
          style={coverStyle}
          aria-hidden="true"
          transition:name={`poster-projects-${entry.id}-image`}
        >
          <span class="cover-initial">{initial}</span>
        </div>

        <div class="hero-meta">
          <div class="row">
            <p class="text-caption muted">project</p>
            <span class:list={['status-pill', 'text-mono-small', `status-${status}`]}>
              {statusLabel[status]}
            </span>
          </div>

          <h1
            class="title text-display"
            transition:name={`poster-projects-${entry.id}-title`}
          >{title}</h1>

          <p class="summary text-body">{summary}</p>

          <p class="meta-line text-caption muted">{dateLabel}</p>

          {
            tags.length > 0 && (
              <ul class="tags" aria-label="tags">
                {tags.map((t) => (
                  <li class="tag-chip text-caption">{t}</li>
                ))}
              </ul>
            )
          }

          {
            links && links.length > 0 && (
              <ul class="links" aria-label="links">
                {links.map((l) => (
                  <li>
                    <a class="link text-small" href={l.url} rel="noopener">
                      {l.label}
                      <span aria-hidden="true">↗</span>
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </div>

      <div class="prose">
        <Content />
      </div>
    </article>

    <RelatedProjects current={entry} />
    <NextPrev current={entry} />
  </main>
</Base>

<style>
  /* Page chrome (margin-left for sidebar, mobile bleed, padding, gap)
     comes from `.detail-page` in global.css. Local rules cover only what's
     specific to this page: hero split, cover, hero-meta, links list. */
  .page {
    max-width: 1080px;
    /* gap from .detail-page is --space-5; tighten between hero and prose */
    gap: var(--space-4);
  }
  .muted {
    color: var(--text-muted);
  }

  /* Hero split: cover left, meta right. The morphing elements (cover, title)
     pick up their position from this grid; transition:name handles the rest. */
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(var(--space-4), 2.5vw, var(--space-6));
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    /* hero is content-driven height with a sensible floor */
    min-height: clamp(320px, 50dvh, 520px);
  }

  .cover {
    /* Same recipe as ProjectsCell .cover so the morph reads continuously. */
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 30% 30%,
        oklch(70% 0.18 var(--hue) / 0.85),
        oklch(35% 0.14 var(--hue-alt) / 0.95) 70%
      );
    color: var(--on-cover);
  }
  .cover-initial {
    /* Bigger than the bento variant — this is the hero. Off-scale on
       purpose: graphic-display, not body text. */
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(96px, 14vw, 200px);
    line-height: 1;
    letter-spacing: -0.04em;
    text-align: center;
    opacity: 0.95;
    mix-blend-mode: screen;
    pointer-events: none;
    user-select: none;
  }

  .hero-meta {
    padding: clamp(var(--space-4), 2.5vw, var(--space-6));
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    min-width: 0;
  }

  .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2);
  }

  .title {
    margin: 0;
    color: var(--text);
  }
  .summary {
    margin: 0;
    color: var(--text);
  }
  .meta-line {
    margin: 0;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .links {
    list-style: none;
    padding: 0;
    margin: auto 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
  .link {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2);
    color: var(--text);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .link:hover,
  .link:focus-visible {
    color: var(--accent);
  }

  @media (max-width: 767px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .cover {
      aspect-ratio: 4 / 3;
      max-height: 40dvh;
    }
    .cover-initial {
      font-size: clamp(72px, 18vw, 120px);
    }
  }
</style>
