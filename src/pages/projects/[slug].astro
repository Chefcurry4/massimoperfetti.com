---
/**
 * Project detail page — the morph destination from the bento ProjectsCell.
 *
 * Hero is a full-bleed two-column split (chosen over a banner-then-text
 * layout — see plan §Resolved):
 *   left  — cover gradient (same coverHueVars(title) as the bento source so
 *           the morph is continuous) plus the title's first letter as the
 *           graphic centerpiece, just like the card.
 *   right — eyebrow + status pill + title (text-display) + summary + tags
 *           + links.
 *
 * Body is `<Content />` from Astro's content-layer `render()`, rendering
 * the markdown body with the body type scale.
 *
 * Mobile (<768px): hero stacks vertically, cover capped at 40dvh.
 *
 * View Transitions naming (CLAUDE.md §View Transitions convention):
 *   poster-projects-{slug}        → wrapping <article>
 *   poster-projects-{slug}-image  → cover gradient
 *   poster-projects-{slug}-title  → <h1>
 */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { coverHueVars } from '../../lib/cover-color';

export async function getStaticPaths() {
  const entries = await getCollection('projects', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'projects'>;
}

const { entry } = Astro.props;
const { title, summary, status, tags, links, date } = entry.data;
const { Content } = await render(entry);

const initial = title.trim().charAt(0).toUpperCase() || '·';
const coverStyle = coverHueVars(title);

const statusLabel: Record<typeof status, string> = {
  live: 'live',
  archived: 'archived',
  'in-progress': 'in progress',
};

const dateLabel = date.toLocaleString('en-US', {
  month: 'long',
  year: 'numeric',
});
---

<Base title={title} description={summary}>
  <main class="page">
    <a href="/" class="back text-caption">← back</a>

    <article
      class="project"
      transition:name={`poster-projects-${entry.id}`}
    >
      <div class="hero">
        <div
          class="cover"
          style={coverStyle}
          aria-hidden="true"
          transition:name={`poster-projects-${entry.id}-image`}
        >
          <span class="cover-initial">{initial}</span>
        </div>

        <div class="hero-meta">
          <div class="row">
            <p class="text-caption muted">project</p>
            <span class:list={['status', 'text-mono-small', `status-${status}`]}>
              {statusLabel[status]}
            </span>
          </div>

          <h1
            class="title text-display"
            transition:name={`poster-projects-${entry.id}-title`}
          >{title}</h1>

          <p class="summary text-body">{summary}</p>

          <p class="meta-line text-caption muted">{dateLabel}</p>

          {
            tags.length > 0 && (
              <ul class="tags" aria-label="tags">
                {tags.map((t) => (
                  <li class="tag text-caption">{t}</li>
                ))}
              </ul>
            )
          }

          {
            links && links.length > 0 && (
              <ul class="links" aria-label="links">
                {links.map((l) => (
                  <li>
                    <a class="link text-small" href={l.url} rel="noopener">
                      {l.label}
                      <span aria-hidden="true">↗</span>
                    </a>
                  </li>
                ))}
              </ul>
            )
          }
        </div>
      </div>

      <div class="body">
        <Content />
      </div>
    </article>
  </main>
</Base>

<style>
  /* Sidebar-aware page container — anchored to --sidebar-rail like the
     bento wall and /book and /about. */
  .page {
    min-height: calc(100dvh - 2 * var(--wall-inset));
    margin: var(--wall-inset);
    margin-left: calc(var(--wall-inset) + var(--sidebar-rail) + var(--sidebar-gap));
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 3vw, 2rem) 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 1080px;
  }
  .muted {
    color: var(--text-muted);
  }
  .back {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
    align-self: flex-start;
  }
  .back:hover,
  .back:focus-visible {
    color: var(--text);
  }

  /* Hero split: cover left, meta right. The morphing elements (cover, title)
     pick up their position from this grid; transition:name handles the rest. */
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
    gap: clamp(1rem, 2.5vw, 2rem);
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
    /* hero is content-driven height with a sensible floor */
    min-height: clamp(320px, 50dvh, 520px);
  }

  .cover {
    /* Same recipe as ProjectsCell .cover so the morph reads continuously. */
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 30% 30%,
        oklch(70% 0.18 var(--hue) / 0.85),
        oklch(35% 0.14 var(--hue-alt) / 0.95) 70%
      );
    color: var(--on-cover);
  }
  .cover-initial {
    /* Bigger than the bento variant — this is the hero. */
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(96px, 14vw, 200px);
    line-height: 1;
    letter-spacing: -0.04em;
    text-align: center;
    opacity: 0.95;
    mix-blend-mode: screen;
    pointer-events: none;
    user-select: none;
  }

  .hero-meta {
    padding: clamp(1.25rem, 2.5vw, 2rem);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }

  .row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
  }
  .status {
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
    background: transparent;
    white-space: nowrap;
  }
  .status-live {
    color: var(--status-live);
    border-color: var(--status-live);
    background: var(--status-live-bg);
  }
  .status-in-progress {
    color: var(--status-progress);
    border-color: var(--status-progress);
    background: var(--status-progress-bg);
  }
  .status-archived {
    color: var(--status-archived);
    background: var(--status-archived-bg);
  }

  .title {
    margin: 0;
    color: var(--text);
  }
  .summary {
    margin: 0;
    color: var(--text);
  }
  .meta-line {
    margin: 0;
  }

  .tags {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }
  .tag {
    padding: 0.18rem 0.5rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    color: var(--text-muted);
  }

  .links {
    list-style: none;
    padding: 0;
    margin: auto 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .link {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--text);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .link:hover,
  .link:focus-visible {
    color: var(--accent);
  }

  /* Body markdown — sized to a comfortable reading measure. The styling
     here is intentionally light; Phase 5 polishes the prose typography. */
  .body {
    max-width: 64ch;
    color: var(--text);
    line-height: 1.65;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .body :global(h2) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 24px;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 1.5rem 0 0.25rem;
    color: var(--text);
  }
  .body :global(h3) {
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 18px;
    line-height: 1.3;
    margin: 1rem 0 0.25rem;
    color: var(--text);
  }
  .body :global(p) {
    margin: 0;
  }
  .body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 0.1em 0.35em;
    border-radius: 4px;
    background: var(--surface);
    border: 1px solid var(--border);
  }
  .body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .body :global(ol),
  .body :global(ul) {
    padding-left: 1.25rem;
    margin: 0;
  }

  @media (max-width: 1023.98px) {
    .page {
      margin: 0;
      padding: 16px 16px 88px;
    }
  }
  @media (max-width: 767px) {
    .hero {
      grid-template-columns: 1fr;
      min-height: 0;
    }
    .cover {
      aspect-ratio: 4 / 3;
      max-height: 40dvh;
    }
    .cover-initial {
      font-size: clamp(72px, 18vw, 120px);
    }
  }
</style>
