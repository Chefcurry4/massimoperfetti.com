---
/**
 * /projects — list of all non-draft projects.
 *
 * Linked from the bento SeeAllCell. Phase 4 ships a minimal list-view; Phase
 * 5 / 8 may polish to a richer index. Ordering: featured first (descending
 * by date), then non-featured. Each row links to /projects/{id}.
 *
 * No view-transition-name on the rows — the bento → detail morph is for
 * featured cards on the home wall. From this list view, navigation is a
 * straight cross-fade (Astro's default).
 */
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';

const entries = (await getCollection('projects', ({ data }) => !data.draft)).sort((a, b) => {
  // featured first, then by date desc
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.date.getTime() - a.data.date.getTime();
});

const statusLabel: Record<CollectionEntry<'projects'>['data']['status'], string> = {
  live: 'live',
  archived: 'archived',
  'in-progress': 'in progress',
};
---

<Base title="Projects" description="All projects.">
  <main class="page">
    <a href="/" class="back text-caption">← back</a>

    <header class="head">
      <p class="text-caption muted">projects</p>
      <h1 class="text-h1 headline">All projects</h1>
      <p class="lede text-body muted">
        {entries.length} in total. Click any row to read the case study.
      </p>
    </header>

    <ul class="list" aria-label="all projects">
      {
        entries.map((entry) => (
          <li>
            <a class="row" href={`/projects/${entry.id}`}>
              <div class="row-main">
                <h2 class="text-h3 row-title">{entry.data.title}</h2>
                <p class="text-small muted row-summary">{entry.data.summary}</p>
              </div>
              <div class="row-meta">
                <span class:list={['status', 'text-mono-small', `status-${entry.data.status}`]}>
                  {statusLabel[entry.data.status]}
                </span>
                <span class="row-date text-caption muted">
                  {entry.data.date.toLocaleString('en-US', {
                    month: 'short',
                    year: 'numeric',
                  })}
                </span>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</Base>

<style>
  .page {
    min-height: calc(100dvh - 2 * var(--wall-inset));
    margin: var(--wall-inset);
    margin-left: calc(var(--wall-inset) + var(--sidebar-rail) + var(--sidebar-gap));
    padding: clamp(1.5rem, 3vw, 2.5rem) clamp(1rem, 3vw, 2rem) 4rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 920px;
  }
  .muted {
    color: var(--text-muted);
  }
  .back {
    color: var(--text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
    align-self: flex-start;
  }
  .back:hover,
  .back:focus-visible {
    color: var(--text);
  }

  .head {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .headline {
    margin: 0;
    color: var(--text);
  }
  .lede {
    margin: 0;
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: baseline;
    padding: 1rem 0;
    border-top: 1px solid var(--border);
    color: inherit;
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .list li:last-child .row {
    border-bottom: 1px solid var(--border);
  }
  .row:hover .row-title,
  .row:focus-visible .row-title {
    color: var(--accent);
  }
  .row:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
  .row-main {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .row-title {
    margin: 0;
    color: var(--text);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .row-summary {
    margin: 0;
    /* one line, ellipsis */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .row-meta {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    white-space: nowrap;
  }
  .status {
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.15rem 0.55rem;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
  }
  .status-live {
    color: var(--status-live);
    border-color: var(--status-live);
    background: var(--status-live-bg);
  }
  .status-in-progress {
    color: var(--status-progress);
    border-color: var(--status-progress);
    background: var(--status-progress-bg);
  }
  .status-archived {
    color: var(--status-archived);
  }

  @media (max-width: 1023.98px) {
    .page {
      margin: 0;
      padding: 16px 16px 88px;
    }
  }
  @media (max-width: 600px) {
    .row {
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .row-meta {
      align-items: flex-start;
      flex-direction: row;
    }
  }
</style>
