---
/**
 * /thanks — post-submit success page for the contact form.
 *
 * Reached via the form's `action="/thanks"` after Netlify accepts a
 * submission. Plain confirmation: visitor lands here, sees the message
 * went through, has a back link.
 *
 * No JS, no telemetry, no autoredirect. Massimo can refine the copy in one
 * place when he wants a different voice.
 */
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
---

<Base title="Thanks" description={`Message received. ${site.name} will reply.`}>
  <main class="detail-page page">
    <article class="card">
      <p class="text-caption muted">contact</p>
      <h1 class="text-display headline">Got it.</h1>
      <p class="lede text-body muted">
        Your message reached the inbox. Massimo replies within a few days,
        usually faster.
      </p>

      <div class="actions">
        <a href="/" class="text-caption back-link">← back to the wall</a>
        <a href="/book" class="text-caption book" data-astro-prefetch>→ book a 30-min call instead</a>
      </div>
    </article>
  </main>
</Base>

<style>
  .page {
    /* Center the success card vertically + horizontally for a pleasant
       arrival state. */
    max-width: 560px;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .muted {
    color: var(--text-muted);
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
    padding: var(--space-6) var(--space-5);
  }
  .headline {
    margin: 0;
    color: var(--text);
  }
  .lede {
    margin: 0;
    max-width: 44ch;
  }

  .actions {
    margin-top: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: center;
  }
  .book {
    color: var(--text-muted);
    transition: color var(--duration-fast) var(--ease-out-expo);
  }
  .book:hover,
  .book:focus-visible {
    color: var(--accent);
  }
</style>
