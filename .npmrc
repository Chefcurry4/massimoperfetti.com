# Hoist canvaskit-wasm to the top-level node_modules so astro-og-canvas can
# resolve the .wasm binary via its internal __dirname-style path lookup.
# Without this, pnpm's symlinked .pnpm store breaks the resolution and the
# OG image build fails with "ReferenceError: __dirname is not defined".
public-hoist-pattern[]=*canvaskit*
shamefully-hoist=false
